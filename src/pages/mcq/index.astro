---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import CourseIcon from '../../components/CourseIcon.astro';

const title = "Maritime STCW Exit Exam MCQ Practice | EFA, FPFF, PST, PSSR | Bright Mariner";
const description = "Practice DG Shipping STCW exit exam MCQs online. Access updated questions for EFA, FPFF, PST, PSSR, TASCO, and more. Improve your pass rate with Bright Mariner.";

const faqs = [
    {
        question: "What is a DG Shipping STCW Exit Exam?",
        answer: "The <strong>DG Shipping Exit Exam</strong> is a mandatory online assessment that maritime students must clear at the end of each STCW modular course to receive their official certificates. The exam tests practical and theoretical safety concepts."
    },
    {
        question: "Which STCW exit exams can I practice on Bright Mariner?",
        answer: "You can practice exit exam questions for multiple STCW modules, including basic safety courses (EFA, FPFF, PST, PSSR, STSDSD), advanced courses (AFF, PSCRB, MFA, TASCO), and refresher modular courses."
    },
    {
        question: "How is the MCQ practice structured?",
        answer: "Questions are grouped into interactive sets of 30 questions each, which mimics the pattern and time constraints of the official DG Shipping examination portal. Explanations are provided for incorrect answers."
    },
    {
        question: "Are these practice tests free to use?",
        answer: "Yes, all practice sets, question explanations, and study resources on Bright Mariner are completely free for all seafarers and maritime professionals."
    }
];

const faqPageSchema = {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
            "@type": "Answer",
            "text": faq.answer.replace(/<\/?[^>]+(>|$)/g, "")
        }
    }))
};

const allQuestions = await getCollection('questions');
const courseIds = [...new Set(allQuestions.map(q => q.data.courseId))];

const categories = [
    {
        name: 'STCW Basic Modular',
        courses: [
            { id: 'efa', name: 'Elementary First Aid (EFA)' },
            { id: 'fpff', name: 'Fire Prevention & Fire Fighting (FPFF)' },
            { id: 'pst', name: 'Personal Survival Techniques (PST)' },
            { id: 'pssr', name: 'Personal Safety & Social Responsibilities (PSSR)' },
            { id: 'stsdsd', name: 'Security Training for Seafarers (STSDSD)' },
            { id: 'bigf', name: 'Basic Training for Ships subject to the IGF Code (BIGF)' },
        ]
    },
    {
        name: 'STCW Advanced',
        courses: [
            { id: 'aff', name: 'Advanced Fire Fighting (AFF)' },
            { id: 'pscrb', name: 'PSCRB (Proficiency in Survival Craft and Rescue Boats)' },
            { id: 'mfa', name: 'Medical First Aid (MFA)' },
            { id: 'tasco', name: 'Advanced Training for Oil Tanker Cargo Operations (TASCO)' },
            { id: 'aigf', name: 'Advanced Training for Ships subject to the IGF Code (AIGF)' },
        ]
    },
    {
        name: 'GP Rating',
        courses: [
            { id: 'gsk', name: 'General Ship Knowledge (GSK)' },
            { id: 'mek', name: 'Marine Engineering Knowledge (MEK)' },
        ]
    },
    {
        name: 'Refresher Courses',
        courses: [
            { id: 'rfpff', name: 'Refresher FPFF' },
        ]
    }
];

// Filter out categories that have no courses with questions
const activeCategories = categories.map(cat => ({
    ...cat,
    courses: cat.courses.filter(course => courseIds.includes(course.id))
})).filter(cat => cat.courses.length > 0);
---

<Layout title={title} description={description}>
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://brightmariner.com/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "MCQ Practice",
                    "item": "https://brightmariner.com/mcq/"
                }
            ]
        }
    </script>
    <!-- FAQPage Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />

    <!-- Hero Section -->
    <section class="relative pt-24 pb-20 md:pt-32 md:pb-24 overflow-hidden mesh-gradient">
        <div class="max-w-5xl mx-auto px-6 lg:px-8 relative z-10">
            <header class="text-left">
                <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full mb-6">
                    <span class="text-[10px] font-mono uppercase tracking-widest text-mute">STCW Exit Exams</span>
                    <span class="text-xs font-medium text-ink">DG Shipping Practice Room</span>
                </div>
                <h1 class="text-4xl md:text-6xl font-semibold tracking-tighter text-ink mb-4">MCQ Practice Room</h1>
                <p class="text-body text-lg max-w-2xl leading-relaxed">
                    Select a course to start your practice. Our questions are curated from the latest DG Shipping exit exams to ensure your success.
                </p>
            </header>
        </div>
        <div class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-hairline to-transparent"></div>
    </section>

    <div class="py-16 px-6 lg:px-8 bg-canvas-soft min-h-[calc(100vh-420px)]">
        <div class="max-w-5xl mx-auto">
            <!-- Display Ad BM -->
            <div class="mb-12 min-h-[100px] overflow-hidden">
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-client="ca-pub-5114473836304357"
                     data-ad-slot="1604989612"
                     data-ad-format="auto"
                     data-full-width-responsive="true"></ins>
                <script is:inline>
                     (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
            </div>

            <div class="space-y-16">
                {activeCategories.map(category => (
                    <section>
                        <h2 class="text-xs font-mono uppercase tracking-widest text-navy mb-8 flex items-center gap-4">
                            {category.name}
                            <div class="h-px flex-grow bg-hairline"></div>
                        </h2>
                        
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {category.courses.map(course => (
                                <a href={`/mcq/${course.id}-exit-exam-questions-answers/`} class="group flex items-center justify-between p-6 bg-canvas border border-hairline rounded-xl hover:border-link/50 hover:shadow-md transition-all">
                                    <div class="flex items-center gap-4">
                                        <div class="w-12 h-12 bg-canvas-soft border border-hairline rounded-lg flex items-center justify-center text-body group-hover:text-link group-hover:bg-canvas group-hover:border-link/30 transition-all shadow-xs flex-shrink-0">
                                            <CourseIcon id={course.id} class="w-6 h-6" />
                                        </div>
                                        <div class="flex flex-col gap-1">
                                            <h3 class="text-lg font-medium text-ink group-hover:text-navy transition-colors">{course.name}</h3>
                                            <div class="flex items-center gap-3">
                                                <span class="text-xs text-mute">{allQuestions.filter(q => q.data.courseId === course.id).length} Questions</span>
                                                <div class="w-1 h-1 rounded-full bg-hairline"></div>
                                                <span class="text-xs text-mute">Latest 2026</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="w-10 h-10 rounded-full border border-hairline flex items-center justify-center group-hover:bg-navy group-hover:border-navy group-hover:text-white transition-all flex-shrink-0">
                                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </a>
                            ))}
                        </div>
                    </section>
                ))}
            </div>
            
            {courseIds.filter(id => !categories.flatMap(c => c.courses).some(c => c.id === id)).length > 0 && (
                <section class="mt-16">
                    <h2 class="text-xs font-mono uppercase tracking-widest text-navy mb-8 flex items-center gap-4">
                        Other Modules
                        <div class="h-px flex-grow bg-hairline"></div>
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        {courseIds.filter(id => !categories.flatMap(c => c.courses).some(c => c.id === id)).map(id => (
                            <a href={`/mcq/${id}-exit-exam-questions-answers/`} class="group flex items-center justify-between p-6 bg-canvas border border-hairline rounded-xl hover:border-link/50 hover:shadow-md transition-all">
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 bg-canvas-soft border border-hairline rounded-lg flex items-center justify-center text-body group-hover:text-link group-hover:bg-canvas group-hover:border-link/30 transition-all shadow-xs flex-shrink-0">
                                        <CourseIcon id={id} class="w-6 h-6" />
                                    </div>
                                    <h3 class="text-lg font-medium text-ink group-hover:text-navy transition-colors">{id.toUpperCase()} Practice</h3>
                                </div>
                                <div class="w-10 h-10 rounded-full border border-hairline flex items-center justify-center group-hover:bg-navy group-hover:border-navy group-hover:text-white transition-all flex-shrink-0">
                                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </div>
                            </a>
                        ))}
                    </div>
                </section>
            )}

            {/* FAQs Section with custom interactive accordion details style */}
            <section class="mt-24 space-y-6" aria-labelledby="faq-title">
                <div class="h-px bg-hairline mb-12"></div>
                <h2 id="faq-title" class="text-2xl font-semibold tracking-tight text-ink">
                    Exit Exam Practice FAQs
                </h2>
                <div class="space-y-4">
                    {faqs.map(faq => (
                        <details class="group bg-canvas border border-hairline rounded-xl [&_summary::-webkit-details-marker]:hidden">
                            <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                                <h3 class="text-lg font-medium text-ink group-open:text-navy transition-colors">
                                    {faq.question}
                                </h3>
                                <span class="ml-1.5 flex-shrink-0 rounded-full bg-canvas p-1.5 text-mute border border-hairline group-open:rotate-180 group-open:text-link group-open:border-link/30 transition-transform duration-300">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                    </svg>
                                </span>
                            </summary>
                            <div class="px-6 pb-6 text-sm text-body leading-relaxed border-t border-hairline pt-4" set:html={faq.answer} />
                        </details>
                    ))}
                </div>
            </section>

            <!-- Multiplex Ad Below FAQs -->
            <div class="mt-16 pt-8 border-t border-hairline min-h-[250px] overflow-hidden">
                <ins class="adsbygoogle"
                     style="display:block"
                     data-ad-format="autorelaxed"
                     data-ad-client="ca-pub-5114473836304357"
                     data-ad-slot="6717715493"></ins>
                <script is:inline>
                     (adsbygoogle = window.adsbygoogle || []).push({});
                </script>
            </div>
        </div>
    </div>
</Layout>
