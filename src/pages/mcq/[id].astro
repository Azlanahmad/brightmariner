---

<Layout title={title} description={description}>
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <!-- FAQPage Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />

    <div class="py-24 px-6 lg:px-8 bg-canvas-soft min-h-[calc(100vh-64px)]">
        <div class="max-w-5xl mx-auto">
            <!-- Breadcrumbs Navigation -->
            <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-mute mb-8" aria-label="Breadcrumb">
                <a href="/mcq/" class="hover:text-ink transition-colors">Practice</a>
                <span>/</span>
                <span class="text-ink">{courseAbbr}</span>
            </nav>

            <!-- Hero/Header Section -->
            <header class="mb-16">
                <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink mb-4">
                    {courseAbbr} Exit Exam Questions and Answers
                </h1>
                <p class="text-body text-lg max-w-3xl leading-relaxed">
                    Prepare with the latest <strong>{courseAbbr} exit exam questions and answers</strong>. Access {courseQuestions.length} high-quality, updated multiple-choice questions organized into interactive practice sets designed to match the official DG Shipping online portal.
                </p>
            </header>

            <!-- Interactive Practice Sets Grid -->
            <section class="mb-20" aria-labelledby="practice-sets-title">
                <h2 id="practice-sets-title" class="text-xs font-mono uppercase tracking-widest text-mute mb-8 flex items-center gap-4">
                    Interactive Practice Sets
                    <div class="h-px flex-grow bg-hairline"></div>
                </h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {sets.map(setNum => (
                        <a href={`/mcq/${id}/${setNum}/`} class="group p-6 bg-canvas border border-hairline rounded-xl hover:border-ink hover:shadow-md transition-all duration-300">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-xs font-mono uppercase tracking-widest text-mute">Set {setNum}</span>
                                <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center group-hover:bg-primary group-hover:border-primary group-hover:text-white transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </div>
                            </div>
                            <h3 class="text-xl font-medium text-ink">Questions { (setNum - 1) * setSize + 1 } - { Math.min(setNum * setSize, courseQuestions.length) }</h3>
                            <p class="text-sm text-body mt-2">Comprehensive practice set for {courseName}.</p>
                        </a>
                    ))}
                </div>
                
                {courseQuestions.length === 0 && (
                    <div class="flex flex-col items-center justify-center py-12 bg-canvas border border-hairline rounded-xl">
                        <h3 class="text-xl font-medium text-ink mb-4">No questions available yet.</h3>
                        <a href="/mcq/" class="text-link hover:underline">Back to MCQ Practice</a>
                    </div>
                )}
            </section>

            <!-- SEO Content Section (Guides & Info) -->
            <section class="grid grid-cols-1 lg:grid-cols-3 gap-12 border-t border-hairline pt-16">
                <!-- Sidebar Quick Info & PDF Download -->
                <div class="lg:col-span-1 space-y-8">
                    <!-- PDF Download Card -->
                    <div class="group relative overflow-hidden bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-linear-to-bl from-blue-500/5 to-transparent rounded-bl-full pointer-events-none"></div>
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-3">PDF Download</h3>
                        <p class="text-sm text-body mb-5 leading-relaxed">
                            Get the complete list of {courseAbbr} exit exam questions and answers in a print-ready PDF format for offline preparation.
                        </p>
                        <a href={`/${baseCourseId}-exit-exam-questions-answers.pdf`} download class="inline-flex items-center justify-center w-full px-5 py-3 bg-primary text-white font-medium rounded-full hover:bg-primary/95 shadow-md shadow-primary/10 transition-all hover:scale-[1.01] gap-2 cursor-pointer text-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Download Questions PDF
                        </a>
                    </div>

                    <!-- Exam Summary Card -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-4">Exam Summary</h3>
                        <dl class="space-y-4 text-sm">
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Course Name</dt>
                                <dd class="font-medium text-ink mt-0.5">{courseName}</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Governing Body</dt>
                                <dd class="font-medium text-ink mt-0.5">DG Shipping, India</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Question Pattern</dt>
                                <dd class="font-medium text-ink mt-0.5">Multiple Choice Questions (MCQ)</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Passing Criteria</dt>
                                <dd class="font-medium text-ink mt-0.5">50% (15 out of 30 marks)</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Total Questions Available</dt>
                                <dd class="font-medium text-ink mt-0.5">{courseQuestions.length} Questions</dd>
                            </div>
                        </dl>
                    </div>

                    <!-- Key Learning Areas Card -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-4">Key Learning Areas</h3>
                        <ul class="space-y-2.5 text-sm text-body">
                            {activeConfig.keyLearningAreas.map(area => (
                                <li class="flex items-start gap-2">
                                    <span class="text-primary font-bold">✓</span>
                                    <span>{area}</span>
                                </li>
                            ))}
                        </ul>
                    </div>

                    <!-- Sidebar Display Ad -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong sticky top-24 min-h-[250px] overflow-hidden">
                        <span class="text-[10px] font-mono uppercase tracking-wider text-mute block mb-2">Advertisement</span>
                        <ins class="adsbygoogle"
                             style="display:block"
                             data-ad-client="ca-pub-5114473836304357"
                             data-ad-slot="1604989612"
                             data-ad-format="auto"
                             data-full-width-responsive="true"></ins>
                        <script is:inline>
                             (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                </div>

                <!-- Detailed Reading Content -->
                <div class="lg:col-span-2 space-y-12">
                    <article class="prose max-w-none text-body">
                        <h2 class="text-3xl font-semibold tracking-tight text-ink mb-6">
                            Overview of the {courseAbbr} Exit Exam Questions and Answers
                        </h2>
                        
                        <p class="leading-relaxed mb-6">
                            {activeConfig.studyGuideIntro}
                        </p>

                        <p class="leading-relaxed mb-6">
                            Under the modern <strong>Ship 07</strong> online examination framework, the questions test candidates on both theoretical and practical safety dimensions. To make sure you clear the exam on your first attempt, we have compiled the full bank of updated <strong>{courseAbbr} exit exam questions</strong> into structured, interactive practice rooms simulating the actual test interface.
                        </p>

                        <!-- In-Article Native Ad -->
                        <div class="my-8 min-h-[100px] overflow-hidden">
                            <span class="text-[10px] font-mono uppercase tracking-wider text-mute block mb-2">Advertisement</span>
                            <ins class="adsbygoogle"
                                 style="display:block; text-align:center;"
                                 data-ad-layout="in-article"
                                 data-ad-format="fluid"
                                 data-ad-client="ca-pub-5114473836304357"
                                 data-ad-slot="7500018972"></ins>
                            <script is:inline>
                                 (adsbygoogle = window.adsbygoogle || []).push({});
                            </script>
                        </div>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Syllabus and Topics Covered in the {courseAbbr} Exit Exam
                        </h3>
                        <p class="leading-relaxed mb-6">
                            To prepare effectively for the <strong>{courseAbbr} exit exam MCQ</strong> test, seafarers must study the core areas of the STCW modular course:
                        </p>
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            {activeConfig.syllabusList.map(item => (
                                <li>{item}</li>
                            ))}
                        </ul>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Exam Structure and Passing Marks on the DG Shipping Portal
                        </h3>
                        <p class="leading-relaxed mb-6">
                            When taking the test on the official <strong>DG Shipping</strong> portal, candidates need to be aware of the following structure:
                        </p>
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            {activeConfig.examPortalDetails.map(detail => (
                                <li>{detail}</li>
                            ))}
                        </ul>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Why Download the {courseAbbr} Exit Exam Questions and Answers PDF?
                        </h3>
                        
                        <p class="leading-relaxed mb-6">
                            Studying online is highly effective, but seafarers often face poor internet connectivity while at sea or traveling. To bridge this gap, we offer a comprehensive <strong>{courseAbbr} exit exam questions and answers PDF</strong>.
                        </p>
                        
                        <p class="leading-relaxed mb-6">
                            By downloading this PDF, you can:
                        </p>
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            <li>Study offline anytime, anywhere, without requiring a network connection.</li>
                            <li>Review all questions sorted by sets, complete with marked correct options and descriptive explanations.</li>
                            <li>Self-test your knowledge by printing the pages or hiding answers to simulate the exam.</li>
                        </ul>
                    </article>

                    <!-- FAQs Section with custom interactive accordion details style -->
                    <section class="space-y-6" aria-labelledby="faq-title">
                        <h2 id="faq-title" class="text-2xl font-semibold tracking-tight text-ink">
                            {courseAbbr} Exit Exam FAQs
                        </h2>
                        <div class="space-y-4">
                            {faqs.map((faq, index) => (
                                <details class="group bg-canvas border border-hairline rounded-xl [&_summary::-webkit-details-marker]:hidden" open={index === 0}>
                                    <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                                        <h3 class="text-lg font-medium text-ink group-open:text-primary transition-colors">
                                            {faq.question}
                                        </h3>
                                        <span class="ml-1.5 flex-shrink-0 rounded-full bg-canvas p-1.5 text-mute border border-hairline group-open:rotate-180 transition-transform duration-300">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </span>
                                    </summary>
                                    <div class="px-6 pb-6 text-sm text-body leading-relaxed border-t border-hairline pt-4" set:html={faq.answer} />
                                </details>
                            ))}
                        </div>
                    </section>

                    <!-- Multiplex Ad Below FAQs -->
                    <div class="mt-16 pt-8 border-t border-hairline min-h-[250px] overflow-hidden">
                        <ins class="adsbygoogle"
                             style="display:block"
                             data-ad-format="autorelaxed"
                             data-ad-client="ca-pub-5114473836304357"
                             data-ad-slot="6717715493"></ins>
                        <script is:inline>
                             (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                </div>
            </section>
        </div>
    </div>
</Layout>
