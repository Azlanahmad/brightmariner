---
import { getCollection, type CollectionEntry } from 'astro:content';
import Layout from '../../../layouts/Layout.astro';
import PracticeRoom from '../../../components/PracticeRoom';

type QuestionData = CollectionEntry<'questions'>['data'];

interface Props {
  questions: QuestionData[];
  setNumber: number;
  totalSets: number;
}

export async function getStaticPaths() {
  const allQuestions = await getCollection('questions');
  const courseIds = allQuestions
    .map((q) => q.data.courseId)
    .filter((value, index, self) => self.indexOf(value) === index);
  
  const paths: Array<{
    params: { id: string; set: string };
    props: Props;
  }> = [];
  
  for (const courseId of courseIds) {
    const courseQuestions = allQuestions
        .filter(q => q.data.courseId === courseId)
        .sort((a, b) => a.id.localeCompare(b.id)); // Sort by ID to ensure stable sets
    
    const setSize = 30;
    const numSets = Math.ceil(courseQuestions.length / setSize);
    
    for (let setIdx = 1; setIdx <= numSets; setIdx++) {
      paths.push({
        params: { id: `${courseId}-exit-exam-questions-answers`, set: setIdx.toString() },
        props: { 
            questions: courseQuestions.slice((setIdx - 1) * setSize, setIdx * setSize).map(q => q.data),
            setNumber: setIdx,
            totalSets: numSets
        }
      });
    }
  }
  
  return paths;
}

const { id, set } = Astro.params;
const { questions, setNumber, totalSets } = Astro.props;

const baseCourseId = id.replace('-exit-exam-questions-answers', '');
const nextSetNumber = setNumber < totalSets ? setNumber + 1 : null;
const nextSetUrl = nextSetNumber ? `/mcq/${id}/${nextSetNumber}/` : null;

// Course ID to Name mapping
const courseNames: Record<string, string> = {
    'efa': 'Elementary First Aid (EFA)',
    'fpff': 'Fire Prevention & Fire Fighting (FPFF)',
    'pst': 'Personal Survival Techniques (PST)',
    'pssr': 'Personal Safety & Social Responsibilities (PSSR)',
    'stsdsd': 'Security Training for Seafarers (STSDSD)',
    'aff': 'Advanced Fire Fighting (AFF)',
    'pscrb': 'PSCRB (Proficiency in Survival Craft and Rescue Boats)',
    'mfa': 'Medical First Aid (MFA)',
    'tasco': 'Advanced Training for Oil Tanker Cargo Operations (TASCO)',
    'refresher': 'Refresher Course',
    'rfpff': 'Refresher FPFF',
    'gsk': 'General Ship Knowledge (GSK)',
    'mek': 'Marine Engineering Knowledge (MEK)'
};

const courseAbbr = baseCourseId === 'refresher' ? 'Refresher' : baseCourseId === 'rfpff' ? 'Refresher FPFF' : baseCourseId.toUpperCase();
const courseName = courseNames[baseCourseId as string] || baseCourseId?.toUpperCase();
const title = `${courseAbbr} Exit Exam MCQ - Set ${setNumber} | Bright Mariner`;
const description = `Practice ${courseName} exit exam questions Set ${setNumber}. Interactive STCW MCQ practice with instant feedback and explanations. Updated for 2026.`;

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://brightmariner.com/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "MCQ Practice",
      "item": "https://brightmariner.com/mcq/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": courseName,
      "item": `https://brightmariner.com/mcq/${id}/`
    },
    {
      "@type": "ListItem",
      "position": 4,
      "name": `Set ${setNumber}`,
      "item": `https://brightmariner.com/mcq/${id}/${setNumber}/`
    }
  ]
};
---

<Layout title={title} description={description}>
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <div class="min-h-[calc(100vh-64px)] bg-canvas-soft">
        <div class="max-w-3xl mx-auto pt-8 px-6">
            <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-mute mb-4">
                <a href="/mcq/" class="hover:text-ink transition-colors">Practice</a>
                <span>/</span>
                <a href={`/mcq/${id}/`} class="hover:text-ink transition-colors">{baseCourseId}</a>
                <span>/</span>
                <span class="text-ink">Set {setNumber}</span>
            </nav>
        </div>
        <PracticeRoom client:load questions={questions} courseName={`${courseName} (Set ${setNumber})`} nextSetUrl={nextSetUrl} />

        <!-- Display Ad BM -->
        <div class="max-w-3xl mx-auto px-6 mt-12 min-h-[100px] overflow-hidden">
            <span class="text-[10px] font-mono uppercase tracking-wider text-mute block mb-2">Advertisement</span>
            <ins class="adsbygoogle"
                 style="display:block"
                 data-ad-client="ca-pub-5114473836304357"
                 data-ad-slot="1604989612"
                 data-ad-format="auto"
                 data-full-width-responsive="true"></ins>
            <script is:inline>
                 (adsbygoogle = window.adsbygoogle || []).push({});
            </script>
        </div>

        <!-- Index of all questions in this set for SEO crawlability and direct access -->
        <div class="max-w-3xl mx-auto pb-24 px-6 mt-16">
            <div class="bg-canvas border border-hairline rounded-2xl p-8 md:p-12 shadow-sm">
                <h3 class="text-lg font-semibold text-ink mb-6 font-sans">Questions in this Practice Set</h3>
                <div class="divide-y divide-hairline">
                    {questions.map((q: QuestionData, index: number) => {
                        const cleanText = q.text
                          .toLowerCase()
                          .replace(/[^\w\s-]/g, '')
                          .replace(/[\s_]+/g, '-')
                          .substring(0, 60)
                          .replace(/^-+|-+$/g, '');
                        const slug = `${cleanText}-${q.id}`;
                        const qUrl = `/mcq/${id}/${setNumber}/${slug}/`;
                        
                        return (
                            <div class="py-4 flex gap-4 items-start">
                                <span class="text-sm font-mono text-mute shrink-0 w-8">Q{index + 1}</span>
                                <div class="flex-grow">
                                    <a href={qUrl} class="text-sm text-body hover:text-link font-medium leading-relaxed transition-colors">
                                        {q.text}
                                    </a>
                                </div>
                            </div>
                        );
                    })}
                </div>
            </div>
        </div>
    </div>
</Layout>
