---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Fetch all questions for courseId === 'gsk'
const allQuestions = await getCollection('questions');
const courseQuestions = allQuestions.filter(q => q.data.courseId === 'gsk');

// Determine sets: Use the 'set' field from data if available, otherwise fallback to groups of 30
const uniqueSetsInData = [...new Set(courseQuestions.map(q => q.data.set).filter(Boolean))];

let sets: number[] = [];
const setSize = 30;

if (uniqueSetsInData.length > 0) {
    sets = (uniqueSetsInData as number[]).sort((a, b) => a - b);
} else {
    const numSets = Math.ceil(courseQuestions.length / setSize);
    sets = Array.from({ length: numSets }, (_, i) => i + 1);
}

const courseName = 'General Ship Knowledge (GSK)';
const title = 'GSK Exit Exam Questions & Answers | GP Rating Online Exam Prep';
const description = 'Prepare with our free gsk online test and practice gp rating exam questions. Access GSK exit exam chapter wise questions, and download the Gsk exit exam practice pdf free download for STCW chapters.';
---

<Layout title={title} description={description}>
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://brightmariner.com/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "MCQ Practice",
                    "item": "https://brightmariner.com/mcq/"
                },
                {
                    "@type": "ListItem",
                    "position": 3,
                    "name": "GSK Exit Exam Questions and Answers",
                    "item": "https://brightmariner.com/mcq/gsk-exit-exam-questions-answers/"
                }
            ]
        }
    </script>

    <!-- FAQPage Structured Data for Rich Snippets -->
    <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Where can I find a reliable gsk online test for practice?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Bright Mariner provides the best interactive gsk online test room on this page. Our platform lets you practice authentic gsk question sets that are regularly updated to match the latest DG Shipping online databases."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How do I get a Gsk exit exam practice pdf free download?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "You can get a comprehensive Gsk exit exam practice pdf free download from the download card on our sidebar. The PDF contains 30 selected practice questions, multiple-choice options, correct answers, and clear explanations for offline study."
                    }
                },
                {
                    "@type": "Question",
                    "name": "What topics are tested in the gp rating online exam?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "The gp rating online exam tests seafarers on key General Ship Knowledge (GSK) topics such as seamanship, ship construction terminology, anchor operations, knots and splices, cargo handling, and standard watchkeeping duties."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Are these GP Exit Exam practice questions similar to the merchant navy exam question paper?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, our GP Exit Exam practice questions cover the most frequently asked questions and syllabus areas. Practicing here helps you understand the difficulty level and patterns of a real merchant navy exam question paper."
                    }
                }
            ]
        }
    </script>

    <div class="py-24 px-6 lg:px-8 bg-canvas-soft min-h-[calc(100vh-64px)]">
        <div class="max-w-5xl mx-auto">
            <!-- Breadcrumbs Navigation -->
            <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-mute mb-8" aria-label="Breadcrumb">
                <a href="/mcq/" class="hover:text-ink transition-colors">Practice</a>
                <span>/</span>
                <span class="text-ink">GSK</span>
            </nav>

            <!-- Hero/Header Section -->
            <header class="mb-16">
                <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink mb-4">
                    GSK Exit Exam Questions and Answers
                </h1>
                <p class="text-body text-lg max-w-3xl leading-relaxed">
                    Prepare with the best <strong>gsk online test</strong> and review every essential <strong>gsk question</strong>. Access {courseQuestions.length} high-quality, updated multiple-choice questions organized into <strong>GSK exit exam chapter wise questions</strong> designed to match the official DG Shipping online portal.
                </p>
            </header>

            <!-- Interactive Practice Sets Grid -->
            <section class="mb-20" aria-labelledby="practice-sets-title">
                <h2 id="practice-sets-title" class="text-xs font-mono uppercase tracking-widest text-mute mb-8 flex items-center gap-4">
                    Interactive Practice Sets
                    <div class="h-px flex-grow bg-hairline"></div>
                </h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {sets.map(setNum => (
                        <a href={`/mcq/gsk-exit-exam-questions-answers/${setNum}/`} class="group p-6 bg-canvas border border-hairline rounded-xl hover:border-ink hover:shadow-md transition-all duration-300">
