---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

// Fetch all questions for courseId === 'aff'
const allQuestions = await getCollection('questions');
const courseQuestions = allQuestions.filter(q => q.data.courseId === 'aff');

// Determine sets: Use the 'set' field from data if available, otherwise fallback to groups of 30
const uniqueSetsInData = [...new Set(courseQuestions.map(q => q.data.set).filter(Boolean))];

let sets: number[] = [];
const setSize = 30;

if (uniqueSetsInData.length > 0) {
    sets = (uniqueSetsInData as number[]).sort((a, b) => a - b);
} else {
    const numSets = Math.ceil(courseQuestions.length / setSize);
    sets = Array.from({ length: numSets }, (_, i) => i + 1);
}

const courseName = 'Advanced Fire Fighting (AFF)';
const title = 'AFF Exit Exam MCQ Questions & Answers | Bright Mariner';
const description = 'Practice updated AFF exit exam questions online. Study Advanced Fire Fighting MCQs. Master your aff STCW exams with Bright Mariner.';
---

<Layout title={title} description={description}>
    <!-- Breadcrumb Structured Data -->
    <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://brightmariner.com/"
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "MCQ Practice",
                    "item": "https://brightmariner.com/mcq/"
                },
                {
                    "@type": "ListItem",
                    "position": 3,
                    "name": "Advanced Fire Fighting (AFF)",
                    "item": "https://brightmariner.com/mcq/aff-exit-exam-questions-answers/"
                }
            ]
        }
    </script>

    <!-- FAQPage Structured Data for Rich Snippets -->
    <script type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "What topics are covered in the AFF exit exam questions?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "The AFF exit exam questions cover advanced firefighting techniques, command and control during firefighting operations, crew organization, fire detection and warning systems, ventilation controls, and maintenance of specialized firefighting equipment as per DG Marine standards."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Where can I find AFF exit exam questions Ship 07?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "You can find and practice the updated AFF exit exam questions for the Ship 07 portal directly on Bright Mariner. Our platform organizes the questions into interactive practice sets containing the latest DG Shipping multiple-choice questions."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Are these AFF exit exam questions compliant with DG Marine requirements?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes, all AFF exit exam questions provided on Bright Mariner are compliant with DG Marine (Directorate General of Shipping) regulations. They are curated from recent exams to reflect the exact pattern, syllabus, and difficulty level of the official maritime examinations."
                    }
                }
            ]
        }
    </script>

    <div class="py-24 px-6 lg:px-8 bg-canvas-soft min-h-[calc(100vh-64px)]">
        <div class="max-w-5xl mx-auto">
            <!-- Breadcrumbs Navigation -->
            <nav class="flex items-center gap-2 text-xs font-mono uppercase tracking-widest text-mute mb-8" aria-label="Breadcrumb">
                <a href="/mcq/" class="hover:text-ink transition-colors">Practice</a>
                <span>/</span>
                <span class="text-ink">AFF</span>
            </nav>

            <!-- Hero/Header Section -->
            <header class="mb-16">
                <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-ink mb-4">
                    Advanced Fire Fighting (AFF) Exit Exam Questions
                </h1>
                <p class="text-body text-lg max-w-3xl leading-relaxed">
                    Most asked questions in AFF exit Exam. Advanced Fire Fighting (AFF) Exit Exam Questions
                </p>
            </header>

            <!-- Interactive Practice Sets Grid -->
            <section class="mb-20" aria-labelledby="practice-sets-title">
                <h2 id="practice-sets-title" class="text-xs font-mono uppercase tracking-widest text-mute mb-8 flex items-center gap-4">
                    Interactive Practice Sets
                    <div class="h-px flex-grow bg-hairline"></div>
                </h2>

                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                    {sets.map(setNum => (
                        <a href={`/mcq/aff-exit-exam-questions-answers/${setNum}/`} class="group p-6 bg-canvas border border-hairline rounded-xl hover:border-ink hover:shadow-md transition-all duration-300">
                            <div class="flex items-center justify-between mb-4">
                                <span class="text-xs font-mono uppercase tracking-widest text-mute">Set {setNum}</span>
                                <div class="w-8 h-8 rounded-full border border-hairline flex items-center justify-center group-hover:bg-primary group-hover:border-primary group-hover:text-white transition-all duration-300">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </div>
                            </div>
                            <h3 class="text-xl font-medium text-ink">Questions { (setNum - 1) * setSize + 1 } - { Math.min(setNum * setSize, courseQuestions.length) }</h3>
                            <p class="text-sm text-body mt-2">Comprehensive practice set for {courseName}.</p>
                        </a>
                    ))}
                </div>
                
                {courseQuestions.length === 0 && (
                    <div class="flex flex-col items-center justify-center py-12 bg-canvas border border-hairline rounded-xl">
                        <h3 class="text-xl font-medium text-ink mb-4">No questions available yet.</h3>
                        <a href="/mcq/" class="text-link hover:underline">Back to MCQ Practice</a>
                    </div>
                )}
            </section>

            <!-- SEO Content Section (Guides & Info) -->
            <section class="grid grid-cols-1 lg:grid-cols-3 gap-12 border-t border-hairline pt-16">
                <!-- Sidebar Quick Info & PDF Download -->
                <div class="lg:col-span-1 space-y-8">
                    <!-- PDF Download Card -->
                    <div class="group relative overflow-hidden bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-linear-to-bl from-blue-500/5 to-transparent rounded-bl-full pointer-events-none"></div>
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-3">PDF Download</h3>
                        <p class="text-sm text-body mb-5 leading-relaxed">
                            Get the complete list of AFF exit exam questions and answers in a print-ready PDF format for offline preparation.
                        </p>
                        <a href="/aff-exit-exam-questions-answers.pdf" download class="inline-flex items-center justify-center w-full px-5 py-3 bg-primary text-white font-medium rounded-full hover:bg-primary/95 shadow-md shadow-primary/10 transition-all hover:scale-[1.01] gap-2 cursor-pointer text-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                            </svg>
                            Download Questions PDF
                        </a>
                    </div>

                    <!-- Exam Summary Card -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-4">Exam Summary</h3>
                        <dl class="space-y-4 text-sm">
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Course Name</dt>
                                <dd class="font-medium text-ink mt-0.5">Advanced Fire Fighting (AFF)</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Governing Body</dt>
                                <dd class="font-medium text-ink mt-0.5">DG Shipping, India (DG Marine)</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Question Pattern</dt>
                                <dd class="font-medium text-ink mt-0.5">Multiple Choice Questions (MCQ)</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Portal Compatibility</dt>
                                <dd class="font-medium text-ink mt-0.5">Ship 07 compatible</dd>
                            </div>
                            <div>
                                <dt class="font-mono text-mute uppercase text-xs">Total Questions Available</dt>
                                <dd class="font-medium text-ink mt-0.5">{courseQuestions.length} Questions</dd>
                            </div>
                        </dl>
                    </div>

                    <!-- Key Learning Areas Card -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong">
                        <h3 class="text-sm font-semibold tracking-wider uppercase text-ink mb-4">Key Learning Areas</h3>
                        <ul class="space-y-2.5 text-sm text-body">
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold">✓</span>
                                <span>Firefighting command & control on ships</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold">✓</span>
                                <span>Ventilation control & compartment isolation</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold">✓</span>
                                <span>Fixed fire extinguishing systems (CO2, foam)</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold">✓</span>
                                <span>Fire detection & warning systems</span>
                            </li>
                            <li class="flex items-start gap-2">
                                <span class="text-primary font-bold">✓</span>
                                <span>Search & rescue operations in smoke</span>
                            </li>
                        </ul>
                    </div>

                    <!-- Sidebar Display Ad -->
                    <div class="group bg-canvas border border-hairline rounded-2xl p-6 card-shadow transition-all duration-300 hover:border-hairline-strong sticky top-24 min-h-[250px] overflow-hidden">
                        <span class="text-[10px] font-mono uppercase tracking-wider text-mute block mb-2">Advertisement</span>
                        <ins class="adsbygoogle"
                             style="display:block"
                             data-ad-client="ca-pub-5114473836304357"
                             data-ad-slot="1604989612"
                             data-ad-format="auto"
                             data-full-width-responsive="true"></ins>
                        <script is:inline>
                             (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                </div>

                <!-- Detailed Reading Content -->
                <div class="lg:col-span-2 space-y-12">
                    <article class="prose max-w-none text-body">
                        <h2 class="text-3xl font-semibold tracking-tight text-ink mb-6">
                            How to Master the STCW AFF Exit Exam Questions
                        </h2>
                        
                        <p class="leading-relaxed mb-6">
                            The <strong>Advanced Fire Fighting (AFF) exit exam</strong> is a mandatory assessment under the <strong>DG Marine</strong> (Directorate General of Shipping, India) guidelines. Obtaining the STCW AFF certificate requires seafarers to display a comprehensive understanding of shipboard fire safety, tactical response, and organizational leadership during fire emergencies.
                        </p>

                        <p class="leading-relaxed mb-6">
                            With the release of the updated <strong>Ship 07</strong> exam system, the question patterns and technical descriptions have been refined. Candidates are tested on complex fire dynamics, ventilation tactics, and emergency operations. To help you succeed, we have consolidated the latest <strong>aff exit exam questions</strong> into structured, interactive practice rooms designed to mimic the actual online exam experience.
                        </p>

                        <!-- In-Article Native Ad -->
                        <div class="my-8 min-h-[100px] overflow-hidden">
                            <span class="text-[10px] font-mono uppercase tracking-wider text-mute block mb-2">Advertisement</span>
                            <ins class="adsbygoogle"
                                 style="display:block; text-align:center;"
                                 data-ad-layout="in-article"
                                 data-ad-format="fluid"
                                 data-ad-client="ca-pub-5114473836304357"
                                 data-ad-slot="7500018972"></ins>
                            <script is:inline>
                                 (adsbygoogle = window.adsbygoogle || []).push({});
                            </script>
                        </div>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Syllabus and Focus Areas of the DG Marine AFF Exit Exam
                        </h3>
                        <p class="leading-relaxed mb-6">
                            To perform well on the <strong>aff exit exam questions dg marine</strong> portal, candidate officers and crew need to understand the theoretical and practical dimensions of shipboard emergency response:
                        </p>
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            <li><strong>Chemistry and Theory of Fire:</strong> In-depth knowledge of the fire tetrahedron, classes of fire (A, B, C, D), and heat transfer methods (conduction, convection, radiation).</li>
                            <li><strong>Firefighting Equipment Operation:</strong> Correct usage procedures for SCBA (Self-Contained Breathing Apparatus), standard egress timings, fixed gas systems (CO2 flooding, Halon substitutes), and the International Shore Connection (ISC).</li>
                            <li><strong>Tactics and Communication:</strong> Implementing boundary cooling, utilizing fire hoses with appropriate spray patterns, organizing fire control parties, and establishing clear lines of command.</li>
                        </ul>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Exam Format and Rules on the Ship 07 Portal
                        </h3>
                        <p class="leading-relaxed mb-6">
                            Preparing for the <strong>aff exit exam questions ship 07</strong> requires familiarity with the current digital testing interface:
                        </p>
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            <li><strong>Question Volume:</strong> The exam presents exactly 30 multiple-choice questions (MCQs) selected randomly from the updated question bank.</li>
                            <li><strong>Passing Threshold:</strong> A score of 50% (15 correct answers out of 30) is required to successfully pass the examination.</li>
                            <li><strong>Time Management:</strong> Questions cover both simple terminology and more complex case scenarios. Budgeting your time helps make sure you can read every question carefully.</li>
                        </ul>

                        <h3 class="text-2xl font-medium tracking-tight text-ink mt-8 mb-4">
                            Why Practice DG Marine AFF Questions on Bright Mariner?
                        </h3>
                        
                        <p class="leading-relaxed mb-6">
                            Our platform provides multiple benefits to optimize your study workflow:
                        </p>
                        
                        <ul class="list-disc pl-6 space-y-3 mb-6">
                            <li>
                                <strong>Updated Question Bank:</strong> Continuous monitoring helps keep the questions aligned with current <strong>aff exit exam questions ship 07</strong> parameters.
                            </li>
                            <li>
                                <strong>Instant Feedback:</strong> Check your choices in real-time with comprehensive answers and context details.
                            </li>
                            <li>
                                <strong>Divided Practice Sets:</strong> Splitting the collection into bite-sized sets of 30 questions optimizes active recall and keeps focus high.
                            </li>
                            <li>
                                <strong>Mobile Optimized:</strong> Study on the go on any device with our fully responsive design.
                            </li>
                        </ul>
                    </article>

                    <!-- FAQs Section with custom interactive accordion details style -->
                    <section class="space-y-6" aria-labelledby="faq-title">
                        <h2 id="faq-title" class="text-2xl font-semibold tracking-tight text-ink">
                            AFF Exit Exam FAQs
                        </h2>
                        <div class="space-y-4">
                            <details class="group bg-canvas border border-hairline rounded-xl [&_summary::-webkit-details-marker]:hidden">
                                <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                                    <h3 class="text-lg font-medium text-ink group-open:text-primary transition-colors">
                                        What topics are covered in the AFF exit exam questions?
                                    </h3>
                                    <span class="ml-1.5 flex-shrink-0 rounded-full bg-canvas p-1.5 text-mute border border-hairline group-open:rotate-180 transition-transform duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </span>
                                </summary>
                                <div class="px-6 pb-6 text-sm text-body leading-relaxed border-t border-hairline pt-4">
                                    The <strong>aff exit exam questions</strong> are based on the standard IMO model course and cover advanced firefighting tactics, firefighting command & control, fixed fire suppression systems, detection instrumentation, boundary cooling, and international regulations under SOLAS.
                                </div>
                            </details>

                            <details class="group bg-canvas border border-hairline rounded-xl [&_summary::-webkit-details-marker]:hidden">
                                <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                                    <h3 class="text-lg font-medium text-ink group-open:text-primary transition-colors">
                                        Where can I find AFF exit exam questions Ship 07?
                                    </h3>
                                    <span class="ml-1.5 flex-shrink-0 rounded-full bg-canvas p-1.5 text-mute border border-hairline group-open:rotate-180 transition-transform duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </span>
                                </summary>
                                <div class="px-6 pb-6 text-sm text-body leading-relaxed border-t border-hairline pt-4">
                                    Bright Mariner compiles authentic <strong>aff exit exam questions ship 07</strong> sets directly on this portal. Practicing our sets helps you familiarise yourself with the newest database additions of the Ship 07 standard.
                                </div>
                            </details>

                            <details class="group bg-canvas border border-hairline rounded-xl [&_summary::-webkit-details-marker]:hidden">
                                <summary class="flex items-center justify-between p-6 cursor-pointer select-none">
                                    <h3 class="text-lg font-medium text-ink group-open:text-primary transition-colors">
                                        Are these AFF exit exam questions compliant with DG Marine?
                                    </h3>
                                    <span class="ml-1.5 flex-shrink-0 rounded-full bg-canvas p-1.5 text-mute border border-hairline group-open:rotate-180 transition-transform duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </span>
                                </summary>
                                <div class="px-6 pb-6 text-sm text-body leading-relaxed border-t border-hairline pt-4">
                                    Yes, all practice material is curated specifically to match the <strong>aff exit exam questions dg marine</strong> standards. Practicing here helps you cover all official topics requested by the Directorate General of Shipping.
                                </div>
                            </details>
                        </div>
                    </section>

                    <!-- Multiplex Ad Below FAQs -->
                    <div class="mt-16 pt-8 border-t border-hairline min-h-[250px] overflow-hidden">
                        <ins class="adsbygoogle"
                             style="display:block"
                             data-ad-format="autorelaxed"
                             data-ad-client="ca-pub-5114473836304357"
                             data-ad-slot="6717715493"></ins>
                        <script is:inline>
                             (adsbygoogle = window.adsbygoogle || []).push({});
                        </script>
                    </div>
                </div>
            </section>
        </div>
    </div>
</Layout>
