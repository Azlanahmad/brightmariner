---
import Layout from '../layouts/Layout.astro';
---

<Layout 
    title="Contact Us | BrightMariner"
    description="Get in touch with the BrightMariner team. For general inquiries, support with STCW exit exams, or business partnership opportunities, reach out here."
>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-36 overflow-hidden mesh-gradient">
        <div class="max-w-(--page-width) mx-auto px-6 lg:px-8 relative z-10 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full mb-8 shadow-xs">
                <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
                <span class="text-xs font-medium text-ink">We're Online & Responsive</span>
            </div>
            
            <h1 class="text-5xl md:text-7xl font-semibold tracking-tighter text-ink mb-6 max-w-4xl mx-auto">
                Get in Touch.
            </h1>
            <p class="text-lg md:text-xl text-body mb-10 max-w-2xl mx-auto leading-relaxed">
                Have a question about our DG Shipping STCW exit exam practice sets, need help with your account, or want to explore partnerships? Let us know.
            </p>
        </div>
        
        <div class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-hairline to-transparent"></div>
    </section>

    <!-- Main Content Section -->
    <section class="py-20 bg-canvas">
        <div class="max-w-(--page-width) mx-auto px-6 lg:px-8">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">
                
                <!-- Left Column: Contact Cards -->
                <div class="lg:col-span-5 space-y-8">
                    <div>
                        <h2 class="text-3xl font-semibold tracking-tight text-ink mb-3">Reach Out Directly</h2>
                        <p class="text-body text-base mb-8">
                            Select the channel that works best for you. Our team of mariners is always ready to guide you.
                        </p>
                    </div>

                    <!-- General Support Card -->
                    <div class="group p-6 bg-canvas-soft border border-hairline hover:border-hairline-strong rounded-2xl transition-all duration-300 card-shadow relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-linear-to-bl from-blue-500/5 to-transparent rounded-bl-full pointer-events-none"></div>
                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-canvas border border-hairline rounded-xl text-blue-600 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                </svg>
                            </div>
                            <div class="space-y-1 flex-1">
                                <h3 class="text-lg font-semibold text-ink">General Support</h3>
                                <p class="text-sm text-body">For practice questions, exit exams help, or technical issues.</p>
                                <div class="pt-2 flex items-center gap-2 flex-wrap">
                                    <a href="mailto:contact.brightmariner@gmail.com" class="text-sm font-semibold text-link hover:text-link-deep break-all">
                                        contact.brightmariner@gmail.com
                                    </a>
                                    <button 
                                        type="button" 
                                        class="copy-btn inline-flex items-center gap-1 px-2 py-1 bg-canvas border border-hairline hover:border-hairline-strong rounded-md text-xs font-medium text-mute hover:text-ink transition-colors cursor-pointer"
                                        data-copy="contact.brightmariner@gmail.com"
                                        aria-label="Copy General Support Email"
                                    >
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                        </svg>
                                        <span class="copy-text">Copy</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Partnerships Card -->
                    <div class="group p-6 bg-canvas-soft border border-hairline hover:border-hairline-strong rounded-2xl transition-all duration-300 card-shadow relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-linear-to-bl from-purple-500/5 to-transparent rounded-bl-full pointer-events-none"></div>
                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-canvas border border-hairline rounded-xl text-purple-600 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <div class="space-y-1 flex-1">
                                <h3 class="text-lg font-semibold text-ink">Business & Partnerships</h3>
                                <p class="text-sm text-body">For custom integrations, corporate training, or sponsorships.</p>
                                <div class="pt-2 flex items-center gap-2 flex-wrap">
                                    <a href="mailto:partner@brightmariner.com" class="text-sm font-semibold text-link hover:text-link-deep break-all">
                                        partner@brightmariner.com
                                    </a>
                                    <button 
                                        type="button" 
                                        class="copy-btn inline-flex items-center gap-1 px-2 py-1 bg-canvas border border-hairline hover:border-hairline-strong rounded-md text-xs font-medium text-mute hover:text-ink transition-colors cursor-pointer"
                                        data-copy="partner@brightmariner.com"
                                        aria-label="Copy Partnerships Email"
                                    >
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3" />
                                        </svg>
                                        <span class="copy-text">Copy</span>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Headquarters Card -->
                    <div class="group p-6 bg-canvas-soft border border-hairline hover:border-hairline-strong rounded-2xl transition-all duration-300 card-shadow relative overflow-hidden">
                        <div class="absolute top-0 right-0 w-24 h-24 bg-linear-to-bl from-orange-500/5 to-transparent rounded-bl-full pointer-events-none"></div>
                        <div class="flex items-start gap-4">
                            <div class="p-3 bg-canvas border border-hairline rounded-xl text-orange-600 group-hover:scale-110 transition-transform duration-300">
                                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                </svg>
                            </div>
                            <div class="space-y-1 flex-grow">
                                <h3 class="text-lg font-semibold text-ink">BrightMariner HQ</h3>
                                <p class="text-sm text-body leading-relaxed">
                                    BrightMariner Headquarters<br>
                                    Mumbai, India
                                </p>
                                <p class="text-xs text-mute pt-2">Feel free to reach out via support before visiting.</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column: Interactive Form -->
                <div class="lg:col-span-7">
                    <div class="p-8 md:p-10 bg-canvas border border-hairline rounded-3xl card-shadow-lg relative overflow-hidden">
                        
                        <!-- Form Success Animation State (Hidden initially) -->
                        <div id="form-success-container" class="hidden flex-col items-center justify-center text-center py-16 space-y-6">
                            <div class="w-20 h-20 bg-emerald-50 text-emerald-500 rounded-full flex items-center justify-center border border-emerald-100 shadow-xs animate-bounce">
                                <svg class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <div class="space-y-2 max-w-md mx-auto">
                                <h3 class="text-2xl font-semibold text-ink">Message Sent Successfully!</h3>
                                <p class="text-sm text-body">
                                    Thank you for contacting us. We have received your inquiry and our support team will respond to you at <span id="success-email-display" class="font-semibold text-ink"></span> shortly.
                                </p>
                            </div>
                            <button 
                                id="reset-form-btn" 
                                type="button" 
                                class="px-6 py-2.5 bg-canvas border border-hairline hover:border-hairline-strong rounded-full text-sm font-medium text-ink transition-colors cursor-pointer"
                            >
                                Send Another Message
                            </button>
                        </div>

                        <!-- Form Main Container -->
                        <form id="contact-form" class="space-y-6" novalidate>
                            <div>
                                <h2 class="text-2xl font-semibold text-ink tracking-tight">Send a Message</h2>
                                <p class="text-sm text-body mt-1">We typically reply within 24 hours.</p>
                            </div>

                            <hr class="border-hairline my-2" />

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                <!-- Name Input -->
                                <div class="space-y-2">
                                    <label for="contact-name" class="text-xs font-mono uppercase tracking-wider text-ink block">Full Name <span class="text-rose-500">*</span></label>
                                    <input 
                                        type="text" 
                                        id="contact-name" 
                                        name="name" 
                                        required 
                                        autocomplete="name"
                                        placeholder="e.g. Capt. Azlan Ahmad" 
                                        class="w-full px-4 py-3 bg-canvas-soft border border-hairline rounded-xl text-base text-ink placeholder-mute focus:outline-hidden focus:border-hairline-strong focus:ring-2 focus:ring-primary/5 transition-all min-h-[48px]"
                                    />
                                    <p id="name-error" class="text-xs text-rose-600 hidden font-medium"></p>
                                </div>

                                <!-- Email Input -->
                                <div class="space-y-2">
                                    <label for="contact-email" class="text-xs font-mono uppercase tracking-wider text-ink block">Email Address <span class="text-rose-500">*</span></label>
                                    <input 
                                        type="email" 
                                        id="contact-email" 
                                        name="email" 
                                        required 
                                        autocomplete="email"
                                        placeholder="e.g. azlan@example.com" 
                                        class="w-full px-4 py-3 bg-canvas-soft border border-hairline rounded-xl text-base text-ink placeholder-mute focus:outline-hidden focus:border-hairline-strong focus:ring-2 focus:ring-primary/5 transition-all min-h-[48px]"
                                    />
                                    <p id="email-error" class="text-xs text-rose-600 hidden font-medium"></p>
                                </div>
                            </div>

                            <!-- Subject dropdown -->
                            <div class="space-y-2">
                                <label for="contact-subject" class="text-xs font-mono uppercase tracking-wider text-ink block">Subject <span class="text-rose-500">*</span></label>
                                <div class="relative">
                                    <select 
                                        id="contact-subject" 
                                        name="subject" 
                                        required 
                                        class="w-full px-4 py-3 bg-canvas-soft border border-hairline rounded-xl text-base text-ink focus:outline-hidden focus:border-hairline-strong focus:ring-2 focus:ring-primary/5 transition-all min-h-[48px] appearance-none cursor-pointer"
                                    >
                                        <option value="" disabled selected>Select an option</option>
                                        <option value="General support">General support / Exit Exam Help</option>
                                        <option value="Partnership Proposal">Partnership Proposal / Collaboration</option>
                                        <option value="Content suggestion">Content Suggestion / MCQ correction</option>
                                        <option value="Other">Other Query</option>
                                    </select>
                                    <div class="absolute inset-y-0 right-4 flex items-center pointer-events-none text-mute">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                        </svg>
                                    </div>
                                </div>
                                <p id="subject-error" class="text-xs text-rose-600 hidden font-medium"></p>
                            </div>

                            <!-- Message text area -->
                            <div class="space-y-2">
                                <label for="contact-message" class="text-xs font-mono uppercase tracking-wider text-ink block">Message <span class="text-rose-500">*</span></label>
                                <textarea 
                                    id="contact-message" 
                                    name="message" 
                                    rows="5" 
                                    required 
                                    placeholder="Tell us how we can help you..." 
                                    class="w-full px-4 py-3 bg-canvas-soft border border-hairline rounded-xl text-base text-ink placeholder-mute focus:outline-hidden focus:border-hairline-strong focus:ring-2 focus:ring-primary/5 transition-all resize-y min-h-[120px]"
                                ></textarea>
                                <p id="message-error" class="text-xs text-rose-600 hidden font-medium"></p>
                            </div>

                            <!-- Newsletter checkbox -->
                            <div class="flex items-start gap-3 pt-2">
                                <div class="relative flex items-center h-5">
                                    <input 
                                        type="checkbox" 
                                        id="contact-subscribe" 
                                        name="subscribe" 
                                        class="w-4.5 h-4.5 rounded border border-hairline text-primary focus:ring-primary/10 cursor-pointer accent-neutral-900"
                                    />
                                </div>
                                <label for="contact-subscribe" class="text-sm text-body cursor-pointer select-none">
                                    Keep me updated with maritime news, study guides, and STCW exam tips.
                                </label>
                            </div>

                            <!-- Form Submit Button -->
                            <div class="pt-4">
                                <button 
                                    type="submit" 
                                    id="submit-form-btn"
                                    class="w-full md:w-auto px-8 py-3.5 bg-primary text-white font-semibold rounded-full hover:bg-primary/95 shadow-md shadow-primary/10 transition-all flex items-center justify-center gap-2 cursor-pointer group hover:scale-[1.01]"
                                >
                                    <span>Send Message</span>
                                    <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3" />
                                    </svg>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-24 bg-canvas-soft border-t border-hairline">
        <div class="max-w-(--page-width) mx-auto px-6 lg:px-8">
            <div class="text-center max-w-2xl mx-auto mb-16">
                <h2 class="text-3xl font-semibold tracking-tight text-ink mb-4">Contact FAQs</h2>
                <p class="text-body text-base">Quick answers to common questions about communicating with BrightMariner.</p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                <div class="space-y-2 p-6 bg-canvas border border-hairline rounded-2xl card-shadow">
                    <h3 class="font-semibold text-lg text-ink">How quickly do you respond?</h3>
                    <p class="text-sm text-body leading-relaxed">
                        We aim to reply to all queries within 24 business hours. If your request is regarding urgent MCQ updates or correction issues, we prioritize them immediately.
                    </p>
                </div>

                <div class="space-y-2 p-6 bg-canvas border border-hairline rounded-2xl card-shadow">
                    <h3 class="font-semibold text-lg text-ink">Can I suggest course revisions?</h3>
                    <p class="text-sm text-body leading-relaxed">
                        Yes! If you spot a spelling error, an outdated answer, or want to contribute new questions, use the form above with subject "Content suggestion" or email us directly.
                    </p>
                </div>

                <div class="space-y-2 p-6 bg-canvas border border-hairline rounded-2xl card-shadow">
                    <h3 class="font-semibold text-lg text-ink">Is there a cost for using BrightMariner?</h3>
                    <p class="text-sm text-body leading-relaxed">
                        BrightMariner is entirely free. It is a community-driven initiative dedicated to helping seafarers master exit exams. We do not charge for access or practice resources.
                    </p>
                </div>

                <div class="space-y-2 p-6 bg-canvas border border-hairline rounded-2xl card-shadow">
                    <h3 class="font-semibold text-lg text-ink">How can we partner with you?</h3>
                    <p class="text-sm text-body leading-relaxed">
                        For partnerships, institutional integrations, or collaborative efforts, please reach out to <a href="mailto:partner@brightmariner.com" class="text-link hover:underline">partner@brightmariner.com</a> or use the contact form.
                    </p>
                </div>
            </div>
        </div>
    </section>
</Layout>

<script is:inline>
    // Copy to Clipboard logic
    document.querySelectorAll('.copy-btn').forEach(button => {
        button.addEventListener('click', async () => {
            const email = button.getAttribute('data-copy');
            const copyTextSpan = button.querySelector('.copy-text');
            
            try {
                await navigator.clipboard.writeText(email);
                
                // Show Success tooltip state
                if (copyTextSpan) {
                    copyTextSpan.textContent = 'Copied!';
                    button.classList.add('bg-emerald-50', 'border-emerald-200', 'text-emerald-700');
                    
                    setTimeout(() => {
                        copyTextSpan.textContent = 'Copy';
                        button.classList.remove('bg-emerald-50', 'border-emerald-200', 'text-emerald-700');
                    }, 2000);
                }
            } catch (err) {
                console.error('Failed to copy text: ', err);
            }
        });
    });

    // Form validation and simulation logic
    const form = document.getElementById('contact-form');
    const formContainer = document.getElementById('contact-form');
    const successContainer = document.getElementById('form-success-container');
    const successEmailDisplay = document.getElementById('success-email-display');
    const resetBtn = document.getElementById('reset-form-btn');
    const submitBtn = document.getElementById('submit-form-btn');

    // Input fields
    const nameInput = document.getElementById('contact-name');
    const emailInput = document.getElementById('contact-email');
    const subjectInput = document.getElementById('contact-subject');
    const messageInput = document.getElementById('contact-message');

    // Error message nodes
    const nameError = document.getElementById('name-error');
    const emailError = document.getElementById('email-error');
    const subjectError = document.getElementById('subject-error');
    const messageError = document.getElementById('message-error');

    function showError(inputNode, errorNode, message) {
        errorNode.textContent = message;
        errorNode.classList.remove('hidden');
        inputNode.classList.add('border-rose-400', 'focus:ring-rose-500/5', 'focus:border-rose-500');
        inputNode.classList.remove('border-hairline', 'focus:border-hairline-strong');
    }

    function clearError(inputNode, errorNode) {
        errorNode.textContent = '';
        errorNode.classList.add('hidden');
        inputNode.classList.remove('border-rose-400', 'focus:ring-rose-500/5', 'focus:border-rose-500');
        inputNode.classList.add('border-hairline', 'focus:border-hairline-strong');
    }

    // Individual field validation
    function validateName() {
        if (!nameInput.value.trim()) {
            showError(nameInput, nameError, 'Full Name is required.');
            return false;
        }
        clearError(nameInput, nameError);
        return true;
    }

    function validateEmail() {
        const emailVal = emailInput.value.trim();
        if (!emailVal) {
            showError(emailInput, emailError, 'Email address is required.');
            return false;
        }
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(emailVal)) {
            showError(emailInput, emailError, 'Please enter a valid email address.');
            return false;
        }
        clearError(emailInput, emailError);
        return true;
    }

    function validateSubject() {
        if (!subjectInput.value) {
            showError(subjectInput, subjectError, 'Please select a subject.');
            return false;
        }
        clearError(subjectInput, subjectError);
        return true;
    }

    function validateMessage() {
        if (!messageInput.value.trim()) {
            showError(messageInput, messageError, 'Message content cannot be empty.');
            return false;
        }
        if (messageInput.value.trim().length < 10) {
            showError(messageInput, messageError, 'Message must be at least 10 characters.');
            return false;
        }
        clearError(messageInput, messageError);
        return true;
    }

    // Add real-time event validation
    nameInput.addEventListener('input', validateName);
    emailInput.addEventListener('input', validateEmail);
    subjectInput.addEventListener('change', validateSubject);
    messageInput.addEventListener('input', validateMessage);

    // Form submit listener
    form.addEventListener('submit', (e) => {
        e.preventDefault();

        // Validate all fields
        const isNameValid = validateName();
        const isEmailValid = validateEmail();
        const isSubjectValid = validateSubject();
        const isMessageValid = validateMessage();

        if (isNameValid && isEmailValid && isSubjectValid && isMessageValid) {
            // Disable button & animate loading
            submitBtn.disabled = true;
            const originalBtnHtml = submitBtn.innerHTML;
            submitBtn.innerHTML = `
                <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
                <span>Sending...</span>
            `;

            // Simulate AJAX request
            setTimeout(() => {
                // Show success view
                successEmailDisplay.textContent = emailInput.value.trim();
                form.classList.add('hidden');
                successContainer.classList.remove('hidden');
                successContainer.classList.add('flex');
                
                // Reset submit button state
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtnHtml;
                
                // Clear input values
                form.reset();
            }, 1000);
        }
    });

    // Reset Form button
    resetBtn.addEventListener('click', () => {
        successContainer.classList.add('hidden');
        successContainer.classList.remove('flex');
        form.classList.remove('hidden');
    });
</script>
