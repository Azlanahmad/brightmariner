---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 1. Generate static paths for every post slug
export async function getStaticPaths() {
	const postEntries = await getCollection('posts');
	return postEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

// 2. Fetch data via props
const { entry } = Astro.props;
const { Content, headings } = await render(entry);

const tocHeadings = headings.filter(h => (h.depth === 2 || h.depth === 3) && h.text.trim() !== "");

const faqPageSchema = entry.data.faqs && entry.data.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": entry.data.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<\/?[^>]+(>|$)/g, "") // Strip HTML tags for schema text
    }
  }))
} : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": entry.data.image ? new URL(entry.data.image, Astro.url).href : "https://brightmariner.com/brightmariner-og.png",
  "datePublished": entry.data.date.toISOString(),
  "dateModified": entry.data.date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Bright Mariner",
    "url": "https://brightmariner.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Bright Mariner",
    "logo": {
      "@type": "ImageObject",
      "url": "https://brightmariner.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

const displayTitle = entry.data.title.length + 17 > 60 
  ? entry.data.title 
  : `${entry.data.title} - Bright Mariner`;
---
<Layout 
	title={displayTitle}
	description={entry.data.description}
	image={entry.data.image}
>
	<!-- Article Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

	{faqPageSchema && (
		<script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
	)}

	<div class="post-page-wrapper">
		<!-- Scroll progress bar -->
		<div class="scroll-progress-container">
			<div class="scroll-progress-bar" id="progressBar"></div>
		</div>

		<!-- Hero Section -->
		<header class="post-hero">
			<div class="hero-container">
				<div class="hero-meta">
					{entry.data.category && <span class="hero-category">{entry.data.category}</span>}
					<time datetime={entry.data.date.toISOString()}>
						{entry.data.date.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						})}
					</time>
				</div>
				<h1 class="hero-title">{entry.data.title}</h1>
				{entry.data.description && <p class="hero-desc">{entry.data.description}</p>}
			</div>
			{entry.data.image && (
				<div class="hero-image-wrap">
					<img 
						src={entry.data.image} 
						alt={entry.data.title} 
						class="hero-image" 
						loading="eager"
						fetchpriority="high"
					/>
				</div>
			)}
		</header>

		<!-- Main Layout Grid -->
		<div class="post-body-container">
			<div class="post-layout-grid no-toc" id="postLayoutGrid">
				<main class="post-content-column">
					<article class="article">
						<div class="content">
							<Content />
						</div>
					</article>

					<!-- Visual FAQ Accordion Section -->
					{entry.data.faqs && entry.data.faqs.length > 0 && (
						<section class="faq-accordion-section">
							<h2 class="faq-title">Frequently Asked Questions</h2>
							<div class="faq-accordion">
								{entry.data.faqs.map((faq, index) => (
									<div class="faq-item" data-index={index}>
										<button class="faq-question-btn" aria-expanded="false" aria-controls={`faq-answer-${index}`}>
											<span class="faq-question-text">{faq.question}</span>
											<svg class="faq-chevron" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
												<polyline points="6 9 12 15 18 9"></polyline>
											</svg>
										</button>
										<div class="faq-answer-wrap" id={`faq-answer-${index}`} role="region">
											<div class="faq-answer-content" set:html={faq.answer} />
										</div>
									</div>
								))}
							</div>
						</section>
					)}
				</main>

				<aside class="post-toc-column" id="tocColumn" style="display: none;">
					<div class="toc-card">
						<h4 class="toc-title">Table of Contents</h4>
						<nav class="toc-nav">
							<ol class="toc-list" id="tocList">
								<!-- Dynamically populated client-side -->
							</ol>
						</nav>
					</div>
				</aside>
			</div>
		</div>
	</div>
</Layout>

<script>
	function setupProgressBar() {
		const progressBar = document.getElementById('progressBar');
		if (!progressBar) return;

		const updateProgressBar = () => {
			const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
			if (totalHeight <= 0) {
				progressBar.style.width = '0%';
				return;
			}
			const progress = (window.scrollY / totalHeight) * 100;
			progressBar.style.width = `${progress}%`;
		};

		window.addEventListener('scroll', updateProgressBar, { passive: true });
		window.addEventListener('resize', updateProgressBar);
		updateProgressBar();
	}

	function setupActiveTOC() {
		const postLayoutGrid = document.getElementById('postLayoutGrid');
		const tocColumn = document.getElementById('tocColumn');
		const tocList = document.getElementById('tocList');
		
		if (!postLayoutGrid || !tocColumn || !tocList) return;

		// 1. Find all H2 and H3 headings inside the article body, excluding FAQ section
		const headings = Array.from(document.querySelectorAll('.content h2, .content h3'))
			.filter(h => !h.closest('.faq-accordion-section') && h.textContent.trim() !== "");

		if (headings.length === 0) {
			postLayoutGrid.classList.add('no-toc');
			tocColumn.style.display = 'none';
			return;
		}

		// 2. Generate unique IDs and populate TOC items
		tocList.innerHTML = '';
		
		headings.forEach((heading, index) => {
			if (!heading.id) {
				const slug = heading.textContent
					.toLowerCase()
					.replace(/[^a-z0-9]+/g, '-')
					.replace(/(^-|-$)/g, '');
				heading.id = slug || `section-${index}`;
			}

			const depth = heading.tagName.toLowerCase() === 'h3' ? 3 : 2;
			
			const li = document.createElement('li');
			li.className = `toc-item depth-${depth}`;
			
			const a = document.createElement('a');
			a.href = `#${heading.id}`;
			a.className = 'toc-link';
			a.setAttribute('data-slug', heading.id);
			a.textContent = heading.textContent;
			
			li.appendChild(a);
			tocList.appendChild(li);
		});

		// 3. Make TOC column visible and configure layout grid
		postLayoutGrid.classList.remove('no-toc');
		tocColumn.style.display = 'block';

		// 4. Scroll spying mechanism to highlight active heading
		const tocLinks = tocList.querySelectorAll('.toc-link');
		const headerOffset = 120; // activation offset from viewport top
		
		function updateActiveHeading() {
			const scrollPosition = window.scrollY;
			let activeHeading = null;
			
			// Calculate each heading's absolute top position
			const headingTops = headings.map(heading => {
				return {
					heading,
					top: heading.getBoundingClientRect().top + window.scrollY
				};
			});

			for (let i = 0; i < headingTops.length; i++) {
				const { heading, top } = headingTops[i];
				if (scrollPosition >= top - headerOffset) {
					activeHeading = heading;
				} else {
					break; // Headings are ordered, so stop checking
				}
			}

			// Fallback: If scrolled near the bottom of the page, activate the last heading
			if ((window.innerHeight + window.scrollY) >= document.documentElement.scrollHeight - 100) {
				activeHeading = headings[headings.length - 1];
			}

			// Fallback: If no heading is passed yet, activate the first one
			if (!activeHeading && headings.length > 0) {
				activeHeading = headings[0];
			}

			if (activeHeading) {
				const activeSlug = activeHeading.id;
				tocLinks.forEach(link => {
					if (link.getAttribute('data-slug') === activeSlug) {
						link.classList.add('active');
					} else {
						link.classList.remove('active');
					}
				});
			}
		}

		window.addEventListener('scroll', updateActiveHeading, { passive: true });
		updateActiveHeading();
	}

	function setupFAQAccordion() {
		const faqItems = document.querySelectorAll('.faq-item');
		if (faqItems.length === 0) return;

		faqItems.forEach(item => {
			const button = item.querySelector('.faq-question-btn');
			if (!button) return;

			button.addEventListener('click', () => {
				const isActive = item.classList.contains('active');
				
				if (isActive) {
					item.classList.remove('active');
					button.setAttribute('aria-expanded', 'false');
				} else {
					item.classList.add('active');
					button.setAttribute('aria-expanded', 'true');
				}
			});
		});
	}

	function initBlogInteractivity() {
		setupProgressBar();
		setupActiveTOC();
		setupFAQAccordion();
	}

	// Run on initial load
	initBlogInteractivity();

	// Run on view transitions (Astro)
	document.addEventListener('astro:after-swap', initBlogInteractivity);
</script>

<style>
	:root {
		--bg-academic: #F8F9FA;
		--text-navy: #0A192F;
		--accent-teal: #00A896;
		--accent-teal-hover: #008274;
		--text-body: #2C3E50;
		--border-soft: #E5E7EB;
		--card-bg: #FFFFFF;
	}

	:global(html) {
		scroll-behavior: smooth;
		scroll-padding-top: 100px;
	}

	.post-page-wrapper {
		background-color: var(--bg-academic);
		min-height: 100vh;
		width: 100%;
		position: relative;
	}

	.scroll-progress-container {
		position: fixed;
		top: 64px; /* Sits exactly below the sticky header (h-16) */
		left: 0;
		width: 100%;
		height: 3px;
		background: transparent;
		z-index: 99;
	}

	.scroll-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--accent-teal);
		transition: width 0.1s ease-out;
	}

	/* Hero Section */
	.post-hero {
		max-width: 1200px;
		margin: 0 auto;
		padding: 64px 20px 32px;
		text-align: center;
	}

	.hero-container {
		max-width: 800px;
		margin: 0 auto 32px;
	}

	.hero-meta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 16px;
		margin-bottom: 16px;
	}

	.hero-category {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 700;
		color: #ffffff;
		background-color: var(--accent-teal);
		padding: 4px 10px;
		border-radius: 4px;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.post-hero time {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-teal);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.hero-title {
		font-size: 44px;
		font-weight: 850;
		line-height: 1.2;
		color: var(--text-navy);
		letter-spacing: -0.03em;
		margin-top: 12px;
		margin-bottom: 16px;
		text-wrap: balance;
	}

	.hero-desc {
		font-size: 18px;
		color: var(--text-body);
		line-height: 1.6;
		max-width: 700px;
		margin: 0 auto;
		text-wrap: pretty;
	}

	.hero-image-wrap {
		max-width: 960px;
		margin: 0 auto;
		border-radius: 16px;
		overflow: hidden;
		box-shadow: 0 10px 30px -5px rgba(10, 25, 47, 0.1);
		border: 1px solid var(--border-soft);
	}

	.hero-image {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 9;
		object-fit: cover;
		display: block;
	}

	/* Main Layout Container */
	.post-body-container {
		max-width: 1200px;
		margin: 0 auto;
		padding: 32px 20px 64px;
	}

	.post-layout-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) 280px;
		gap: 40px;
		align-items: start;
	}

	.post-layout-grid.no-toc {
		grid-template-columns: minmax(0, 1fr);
		max-width: 800px;
		margin: 0 auto;
	}

	.post-content-column {
		display: flex;
		flex-direction: column;
		gap: 48px;
	}

	/* Sidebar TOC */
	.post-toc-column {
		position: sticky;
		top: 100px;
		height: auto;
		max-height: calc(100vh - 140px);
		overflow-y: auto;
	}

	.toc-card {
		background: var(--card-bg);
		border: 1px solid #181d23;
		border-radius: 4px;
		padding: 24px;
		box-shadow: none;
	}

	.toc-title {
		font-size: 16px;
		font-weight: 700;
		color: var(--text-navy);
		margin-top: 0;
		margin-bottom: 16px;
		padding-bottom: 12px;
		border-bottom: 1px solid #ebebeb;
	}

	.toc-nav {
		max-height: 55vh;
		overflow-y: auto;
	}

	.toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		counter-reset: toc-counter;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.toc-item {
		counter-increment: toc-counter;
		position: relative;
		padding-left: 24px;
		font-size: 14px;
		line-height: 1.4;
	}

	.toc-item::before {
		content: counter(toc-counter) ". ";
		position: absolute;
		left: 0;
		font-weight: 600;
		color: var(--text-navy);
	}

	.toc-item.depth-3 {
		padding-left: 40px;
		counter-increment: none; /* Do not increment parent number counter for nested depth 3 items */
	}

	.toc-item.depth-3::before {
		content: "• ";
		left: 24px;
		color: var(--accent-teal);
	}

	.toc-link {
		display: inline-flex;
		align-items: center;
		text-decoration: none;
		color: var(--text-body);
		font-weight: 500;
		transition: all 0.2s ease;
	}

	.toc-link:hover,
	.toc-link.active {
		color: var(--accent-teal);
		font-weight: 600;
	}

	/* Article card adjustments */
	.article {
		background: var(--card-bg);
		padding: 48px;
		border-radius: 16px;
		border: 1px solid var(--border-soft);
		box-shadow: 0px 4px 20px -2px rgba(10, 25, 47, 0.04), 0px 2px 6px -1px rgba(10, 25, 47, 0.02);
	}

	.content {
		line-height: 1.8;
		font-size: 17px;
		color: var(--text-body);
	}

	/* Visual FAQ Accordion */
	.faq-accordion-section {
		background: var(--card-bg);
		border: 1px solid var(--border-soft);
		border-radius: 16px;
		padding: 40px;
		box-shadow: 0px 4px 20px -2px rgba(10, 25, 47, 0.04);
	}

	.faq-title {
		font-size: 24px;
		font-weight: 700;
		color: var(--text-navy);
		margin-top: 0;
		margin-bottom: 24px;
		position: relative;
		padding-bottom: 12px;
		border-bottom: 1px solid var(--border-soft);
	}

	.faq-title::after {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 48px;
		height: 3px;
		background-color: var(--accent-teal);
		border-radius: 2px;
	}

	.faq-accordion {
		display: flex;
		flex-direction: column;
		gap: 16px;
	}

	.faq-item {
		border: 1px solid var(--border-soft);
		border-radius: 8px;
		overflow: hidden;
		background-color: var(--card-bg);
		transition: border-color 0.2s ease, box-shadow 0.2s ease;
	}

	.faq-item:hover {
		border-color: var(--accent-teal);
		box-shadow: 0 4px 12px rgba(0, 168, 150, 0.03);
	}

	.faq-item.active {
		border-color: var(--accent-teal);
		box-shadow: 0 4px 16px rgba(0, 168, 150, 0.05);
	}

	.faq-question-btn {
		width: 100%;
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: 20px 24px;
		background: none;
		border: none;
		text-align: left;
		cursor: pointer;
		font-family: inherit;
		font-size: 16px;
		font-weight: 600;
		color: var(--text-navy);
		transition: color 0.2s ease;
	}

	.faq-question-btn:focus-visible {
		outline: 2px solid var(--accent-teal);
		outline-offset: -2px;
	}

	.faq-chevron {
		color: var(--text-body);
		transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1), color 0.2s ease;
		flex-shrink: 0;
		margin-left: 16px;
	}

	.faq-item.active .faq-chevron {
		transform: rotate(180deg);
		color: var(--accent-teal);
	}

	.faq-answer-wrap {
		display: grid;
		grid-template-rows: 0fr;
		transition: grid-template-rows 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		overflow: hidden;
	}

	.faq-item.active .faq-answer-wrap {
		grid-template-rows: 1fr;
	}

	.faq-answer-content {
		min-height: 0;
		padding: 0 24px 20px;
		font-size: 15px;
		line-height: 1.6;
		color: var(--text-body);
	}

	.faq-answer-content :global(p) {
		margin: 0;
	}

	.faq-answer-content :global(p + p) {
		margin-top: 12px;
	}

	/* Responsive break points */
	@media (max-width: 1024px) {
		.post-layout-grid {
			grid-template-columns: 1fr;
		}
		.post-toc-column {
			display: none;
		}
		.post-body-container {
			padding: 16px 12px 48px;
		}
	}

	@media (max-width: 768px) {
		.post-hero {
			padding: 32px 16px 24px;
		}
		.hero-title {
			font-size: 32px;
		}
		.hero-desc {
			font-size: 15px;
		}
	}

	@media (max-width: 640px) {
		.article {
			padding: 24px 16px;
			border-radius: 12px;
		}
		.faq-accordion-section {
			padding: 24px 16px;
		}
		.faq-question-btn {
			padding: 16px;
			font-size: 15px;
		}
		.faq-answer-content {
			padding: 0 16px 16px;
			font-size: 14px;
		}
	}

	/* Typography & Structure elements inside markdown content */
	.content :global(p) {
		margin-bottom: 24px;
		text-wrap: pretty;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4) {
		color: var(--text-navy);
		font-weight: 700;
		letter-spacing: -0.015em;
		text-wrap: balance;
	}

	.content :global(h1) {
		font-size: 30px;
		margin-top: 48px;
		margin-bottom: 20px;
		padding-bottom: 8px;
		border-bottom: 2px solid var(--border-soft);
	}

	.content :global(h2) {
		font-size: 24px;
		margin-top: 40px;
		margin-bottom: 16px;
		position: relative;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--border-soft);
	}

	.content :global(h2::after) {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 48px;
		height: 3px;
		background-color: var(--accent-teal);
		border-radius: 2px;
	}

	.content :global(h3) {
		font-size: 20px;
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.content :global(a) {
		color: var(--accent-teal);
		text-decoration: underline;
		text-decoration-color: rgba(0, 168, 150, 0.3);
		text-underline-offset: 4px;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.content :global(a:hover) {
		color: var(--accent-teal-hover);
		text-decoration-color: var(--accent-teal-hover);
	}

	.content :global(strong) {
		color: var(--text-navy);
		font-weight: 600;
	}

	/* Lists styling */
	.content :global(ul) {
		list-style-type: disc;
		margin-bottom: 28px;
		padding-left: 24px;
	}

	.content :global(ol) {
		list-style-type: decimal;
		margin-bottom: 28px;
		padding-left: 24px;
	}

	.content :global(li) {
		margin-bottom: 10px;
		padding-left: 4px;
	}

	.content :global(ul > li::marker) {
		color: var(--accent-teal);
	}

	.content :global(ol > li::marker) {
		color: var(--accent-teal);
		font-weight: 600;
	}

	/* Inline callouts and blockquotes */
	.content :global(blockquote) {
		background-color: #f0fbf9; /* light seafoam/teal tint */
		border-left: 4px solid var(--accent-teal);
		padding: 20px 24px;
		border-radius: 4px 12px 12px 4px;
		margin: 32px 0;
		color: var(--text-navy);
	}

	.content :global(blockquote p) {
		margin-bottom: 0;
		font-style: italic;
	}

	/* WordPress Gutenberg Block styling overrides */
	.content :global(.wp-block-buttons) {
