---
import { getCollection, render } from 'astro:content';
import Layout from '../layouts/Layout.astro';

// 1. Generate static paths for every post slug
export async function getStaticPaths() {
	const postEntries = await getCollection('posts');
	return postEntries.map(entry => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}

// 2. Fetch data via props
const { entry } = Astro.props;
const { Content } = await render(entry);

const faqPageSchema = entry.data.faqs && entry.data.faqs.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": entry.data.faqs.map(faq => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.answer.replace(/<\/?[^>]+(>|$)/g, "") // Strip HTML tags for schema text
    }
  }))
} : null;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": entry.data.title,
  "description": entry.data.description,
  "image": entry.data.image ? new URL(entry.data.image, Astro.url).href : "https://brightmariner.com/placeholder-og.jpg",
  "datePublished": entry.data.date.toISOString(),
  "dateModified": entry.data.date.toISOString(),
  "author": {
    "@type": "Organization",
    "name": "Bright Mariner",
    "url": "https://brightmariner.com"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Bright Mariner",
    "logo": {
      "@type": "ImageObject",
      "url": "https://brightmariner.com/favicon.svg"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": Astro.url.href
  }
};

const displayTitle = entry.data.title.length + 17 > 60 
  ? entry.data.title 
  : `${entry.data.title} - Bright Mariner`;
---
<Layout 
	title={displayTitle}
	description={entry.data.description}
	image={entry.data.image}
>
	<!-- Article Structured Data -->
	<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

	{faqPageSchema && (
		<script type="application/ld+json" set:html={JSON.stringify(faqPageSchema)} />
	)}

	<div class="post-page-wrapper">
		<!-- Scroll progress bar -->
		<div class="scroll-progress-container">
			<div class="scroll-progress-bar" id="progressBar"></div>
		</div>

		<main class="post-container">
			<article class="article">
				<header class="header">
					<time datetime={entry.data.date.toISOString()}>
						{entry.data.date.toLocaleDateString('en-US', {
							year: 'numeric',
							month: 'long',
							day: 'numeric'
						})}
					</time>
					<h1 class="title">{entry.data.title}</h1>
				</header>

				<hr class="divider" />

				<div class="content">
					<Content />
				</div>
			</article>
		</main>
	</div>
</Layout>

<script>
	function setupProgressBar() {
		const progressBar = document.getElementById('progressBar');
		if (!progressBar) return;

		const updateProgressBar = () => {
			const totalHeight = document.documentElement.scrollHeight - window.innerHeight;
			if (totalHeight <= 0) {
				progressBar.style.width = '0%';
				return;
			}
			const progress = (window.scrollY / totalHeight) * 100;
			progressBar.style.width = `${progress}%`;
		};

		window.addEventListener('scroll', updateProgressBar, { passive: true });
		window.addEventListener('resize', updateProgressBar);
		updateProgressBar();
	}

	// Run on initial load
	setupProgressBar();

	// Run on view transitions
	document.addEventListener('astro:after-swap', setupProgressBar);
</script>

<style>
	:root {
		--bg-academic: #F8F9FA;
		--text-navy: #0A192F;
		--accent-teal: #00A896;
		--accent-teal-hover: #008274;
		--text-body: #2C3E50;
		--border-soft: #E5E7EB;
		--card-bg: #FFFFFF;
	}

	.post-page-wrapper {
		background-color: var(--bg-academic);
		min-height: 100vh;
		width: 100%;
		position: relative;
	}

	.scroll-progress-container {
		position: fixed;
		top: 64px; /* Sits exactly below the sticky header (h-16) */
		left: 0;
		width: 100%;
		height: 3px;
		background: transparent;
		z-index: 99;
	}

	.scroll-progress-bar {
		height: 100%;
		width: 0%;
		background: var(--accent-teal);
		transition: width 0.1s ease-out;
	}

	.post-container {
		max-width: 800px; /* Increased from 720px for better layout readability */
		margin: 0 auto;
		padding: 48px 20px;
	}

	.article {
		background: var(--card-bg);
		padding: 48px;
		border-radius: 16px;
		border: 1px solid var(--border-soft);
		box-shadow: 0px 4px 20px -2px rgba(10, 25, 47, 0.04), 0px 2px 6px -1px rgba(10, 25, 47, 0.02);
	}

	@media (max-width: 640px) {
		.post-container {
			padding: 24px 12px;
		}
		.article {
			padding: 24px 16px;
			border-radius: 12px;
		}
	}

	.header {
		margin-bottom: 28px;
	}

	time {
		font-family: var(--font-mono);
		font-size: 13px;
		font-weight: 600;
		color: var(--accent-teal);
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.title {
		margin-top: 12px;
		margin-bottom: 0;
		font-size: 38px;
		font-weight: 700;
		line-height: 1.25;
		letter-spacing: -0.02em;
		color: var(--text-navy);
		text-wrap: balance;
	}

	@media (max-width: 640px) {
		.title {
			font-size: 28px;
		}
	}

	.divider {
		border: 0;
		border-top: 1px solid var(--border-soft);
		margin: 28px 0;
	}

	.content {
		line-height: 1.8;
		font-size: 17px;
		color: var(--text-body);
	}

	/* Typography & Structure elements inside markdown content */
	.content :global(p) {
		margin-bottom: 24px;
		text-wrap: pretty;
	}

	.content :global(h1),
	.content :global(h2),
	.content :global(h3),
	.content :global(h4) {
		color: var(--text-navy);
		font-weight: 700;
		letter-spacing: -0.015em;
		text-wrap: balance;
	}

	.content :global(h1) {
		font-size: 30px;
		margin-top: 48px;
		margin-bottom: 20px;
		padding-bottom: 8px;
		border-bottom: 2px solid var(--border-soft);
	}

	.content :global(h2) {
		font-size: 24px;
		margin-top: 40px;
		margin-bottom: 16px;
		position: relative;
		padding-bottom: 8px;
		border-bottom: 1px solid var(--border-soft);
	}

	.content :global(h2::after) {
		content: '';
		position: absolute;
		bottom: -1px;
		left: 0;
		width: 48px;
		height: 3px;
		background-color: var(--accent-teal);
		border-radius: 2px;
	}

	.content :global(h3) {
		font-size: 20px;
		margin-top: 32px;
		margin-bottom: 12px;
	}

	.content :global(a) {
		color: var(--accent-teal);
		text-decoration: underline;
		text-decoration-color: rgba(0, 168, 150, 0.3);
		text-underline-offset: 4px;
		font-weight: 600;
		transition: all 0.2s ease;
	}

	.content :global(a:hover) {
		color: var(--accent-teal-hover);
		text-decoration-color: var(--accent-teal-hover);
	}

	.content :global(strong) {
		color: var(--text-navy);
		font-weight: 600;
	}

	/* Lists styling */
	.content :global(ul) {
		list-style-type: disc;
		margin-bottom: 28px;
		padding-left: 24px;
	}

	.content :global(ol) {
		list-style-type: decimal;
		margin-bottom: 28px;
		padding-left: 24px;
	}

	.content :global(li) {
		margin-bottom: 10px;
		padding-left: 4px;
	}

	.content :global(ul > li::marker) {
		color: var(--accent-teal);
	}

	.content :global(ol > li::marker) {
		color: var(--accent-teal);
		font-weight: 600;
	}

	/* Inline callouts and blockquotes */
	.content :global(blockquote) {
		background-color: #f0fbf9; /* light seafoam/teal tint */
		border-left: 4px solid var(--accent-teal);
		padding: 20px 24px;
		border-radius: 4px 12px 12px 4px;
		margin: 32px 0;
		color: var(--text-navy);
	}

	.content :global(blockquote p) {
		margin-bottom: 0;
		font-style: italic;
	}

	/* WordPress Gutenberg Block styling overrides */
	.content :global(.wp-block-buttons) {
		display: flex;
		flex-wrap: wrap;
		gap: 16px;
		margin: 32px 0;
	}

	.content :global(.wp-block-button__link) {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background-color: var(--accent-teal);
		color: #ffffff !important;
		font-weight: 600;
		font-size: 15px;
		text-decoration: none !important;
		padding: 12px 28px;
		border-radius: 8px;
		box-shadow: 0 2px 4px rgba(0, 168, 150, 0.1);
		transition: all 0.2s ease-in-out;
	}

	.content :global(.wp-block-button__link:hover) {
		background-color: var(--accent-teal-hover);
		transform: translateY(-2px);
		box-shadow: 0 6px 16px rgba(0, 168, 150, 0.25);
	}

	.content :global(figure.wp-block-image) {
		margin: 36px 0;
		text-align: center;
	}

	.content :global(figure.wp-block-image img) {
		max-width: 100%;
		height: auto;
		border-radius: 12px;
		border: 1px solid var(--border-soft);
		box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
		display: inline-block;
	}

	/* RankMath FAQ integration */
	.content :global(.wp-block-rank-math-faq-block) {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin: 40px 0;
	}

	.content :global(.rank-math-faq-item) {
		background: #ffffff;
		border: 1px solid var(--border-soft);
		border-left: 4px solid var(--accent-teal);
		border-radius: 8px;
		padding: 24px;
		box-shadow: 0 2px 8px rgba(10, 25, 47, 0.02);
		transition: all 0.2s ease;
	}

	.content :global(.rank-math-faq-item:hover) {
		transform: translateY(-2px);
		box-shadow: 0 8px 20px rgba(10, 25, 47, 0.06);
		border-left-color: var(--accent-teal-hover);
	}

	.content :global(.rank-math-question) {
		margin: 0 0 12px 0 !important;
		font-size: 18px;
		font-weight: 700;
		color: var(--text-navy);
		line-height: 1.4;
	}

	.content :global(.rank-math-question a) {
		color: inherit !important;
		text-decoration: none !important;
		pointer-events: none; /* Disable underline link styles inside FAQ headers */
	}

	.content :global(.rank-math-answer) {
		font-size: 15px;
		color: var(--text-body);
		line-height: 1.6;
	}
</style>
