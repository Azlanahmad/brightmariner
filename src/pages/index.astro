---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Search from '../components/Search.astro';

const posts = await getCollection('posts');
// Sort articles by publication date in descending order
const sortedPosts = posts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Layout title="Bright Mariner - Marine Engineering, Merchant Navy, DNS Guide">
	<main class="home-container">
		<header class="hero">
			<h1 class="hero-title">Bright Mariner</h1>
			<p class="hero-subtitle">Your Guide for Marine Engineering, Merchant Navy, and DNS Exams</p>
			
			<div class="search-box">
				<Search />
			</div>
		</header>

		<section class="articles-section">
			<h2 class="section-title">Latest Articles</h2>
			<div class="articles-grid">
				{sortedPosts.map(post => (
					<article class="article-card">
						<time datetime={post.data.date.toISOString()}>
							{post.data.date.toLocaleDateString('en-US', {
								year: 'numeric',
								month: 'long',
								day: 'numeric'
							})}
						</time>
						<h3 class="article-title">
							<a href={`/${post.id}/`}>{post.data.title}</a>
						</h3>
						<p class="article-excerpt">{post.data.description}</p>
					</article>
				))}
			</div>
		</section>
	</main>
</Layout>

<style>
	.home-container {
		max-width: 960px;
		margin: 0 auto;
		padding: 64px 24px;
	}
	.hero {
		text-align: center;
		margin-bottom: 64px;
		display: flex;
		flex-direction: column;
		align-items: center;
	}
	.hero-title {
		font-size: 48px;
		font-weight: 600;
		line-height: 1;
		letter-spacing: -2px;
		margin: 0 0 16px 0;
		color: #171717;
	}
	.hero-subtitle {
		font-size: 18px;
		color: #4d4d4d;
		margin: 0 0 32px 0;
		max-width: 600px;
		line-height: 1.5;
	}
	.search-box {
		width: 100%;
		display: flex;
		justify-content: center;
	}
	.articles-section {
		border-top: 1px solid #ebebeb;
		padding-top: 48px;
	}
	.section-title {
		font-size: 24px;
		font-weight: 600;
		letter-spacing: -0.8px;
		margin-bottom: 32px;
		color: #171717;
	}
	.articles-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 32px;
	}
	@media (min-width: 768px) {
		.articles-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}
	.article-card {
		background: #ffffff;
		border: 1px solid #ebebeb;
		border-radius: 8px;
		padding: 24px;
		box-shadow: 0px 2px 2px #0000000a;
		transition: transform 0.15s ease, box-shadow 0.15s ease;
	}
	.article-card:hover {
		transform: translateY(-2px);
		box-shadow: 0px 4px 8px #0000000f;
	}
	time {
		font-family: monospace;
		font-size: 12px;
		color: #888888;
	}
	.article-title {
		font-size: 18px;
		font-weight: 600;
		letter-spacing: -0.4px;
		margin: 8px 0 12px 0;
		line-height: 1.3;
	}
	.article-title a {
		color: #171717;
		text-decoration: none;
	}
	.article-title a:hover {
		color: #0070f3;
	}
	.article-excerpt {
		font-size: 14px;
		color: #4d4d4d;
		line-height: 1.5;
		margin: 0;
	}
</style>
