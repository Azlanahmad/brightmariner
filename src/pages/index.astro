---
import Layout from '../layouts/Layout.astro';
import CourseGrid from '../components/CourseGrid.astro';
---

<Layout>
	<!-- Hero Section -->
	<section class="relative pt-32 pb-48 overflow-hidden mesh-gradient">
		<div class="max-w-(--page-width) mx-auto px-6 lg:px-8 relative z-10 text-center">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-canvas border border-hairline rounded-full mb-8 hover:border-hairline-strong transition-colors cursor-pointer group">
                <span class="text-[10px] font-mono uppercase tracking-widest text-mute">Update</span>
                <span class="text-xs font-medium text-ink">New 2026 Question Sets are Live</span>
                <svg class="w-3 h-3 text-mute group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </div>
            
			<h1 class="text-5xl md:text-7xl font-semibold tracking-tighter text-ink mb-6 max-w-4xl mx-auto">
				Master your DG Exit Exams.
			</h1>
			<p class="text-lg md:text-xl text-body mb-10 max-w-2xl mx-auto leading-relaxed">
				The modern practice platform for DG Shipping STCW exit exams. Updated questions, detailed explanations, and real-time performance tracking.
			</p>
			<div class="flex flex-col sm:flex-row items-center justify-center gap-4">
				<a href="/mcq" class="w-full sm:w-auto px-8 py-3 bg-primary text-white font-medium rounded-full hover:bg-primary/90 shadow-xl shadow-primary/10 transition-all text-center">
					Start Practice
				</a>
			</div>
		</div>
        
        <!-- Decorative grid/pattern could go here -->
        <div class="absolute bottom-0 left-0 right-0 h-px bg-linear-to-r from-transparent via-hairline to-transparent"></div>
	</section>

    <!-- Stats / Trust Section -->
    <section class="py-12 bg-canvas border-b border-hairline">
        <div class="max-w-(--page-width) mx-auto px-6 lg:px-8 flex flex-wrap justify-center gap-12 md:gap-24">
            <div class="text-center">
                <div class="text-2xl font-semibold text-ink">5,000+</div>
                <div class="text-xs font-mono uppercase tracking-wider text-mute">Questions</div>
            </div>
            <div class="text-center">
                <div class="text-2xl font-semibold text-ink">25+</div>
                <div class="text-xs font-mono uppercase tracking-wider text-mute">Courses</div>
            </div>
            <div class="text-center">
                <div class="text-2xl font-semibold text-ink">10,000+</div>
                <div class="text-xs font-mono uppercase tracking-wider text-mute">Students</div>
            </div>
            <div class="text-center">
                <div class="text-2xl font-semibold text-ink">98%</div>
                <div class="text-xs font-mono uppercase tracking-wider text-mute">Pass Rate</div>
            </div>
        </div>
    </section>

	<CourseGrid />
    
    <!-- Feature Section -->
    <section class="py-24 bg-canvas-soft">
        <div class="max-w-(--page-width) mx-auto px-6 lg:px-8">
            <div class="text-center mb-16">
                <h2 class="text-3xl font-semibold tracking-tight text-ink mb-4">Why BrightMariner?</h2>
                <p class="text-body text-lg max-w-2xl mx-auto">We've built a platform that's better than anything else available, focused on student success.</p>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 bg-canvas border border-hairline rounded-lg flex items-center justify-center shadow-sm">
                        <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-ink">Instant Feedback</h3>
                    <p class="text-body text-sm leading-relaxed">Don't just memorize answers. Understand the concepts with instant corrections and detailed explanations for every question.</p>
                </div>
                
                <div class="flex flex-col gap-4">
                    <div class="w-12 h-12 bg-canvas border border-hairline rounded-lg flex items-center justify-center shadow-sm">
                        <svg class="w-6 h-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-ink">Smart Analytics</h3>
                    <p class="text-body text-sm leading-relaxed">Track your progress. See which topics you've mastered and where you need more practice with our visual progress bars.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Final CTA -->
    <section class="py-24 bg-primary text-white overflow-hidden relative mesh-gradient-dark">
        <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
            <h2 class="text-4xl font-semibold tracking-tight mb-6">Ready to clear your exams?</h2>
            <p class="text-xl text-white/80 mb-10 leading-relaxed">Join thousands of maritime students who trust BrightMariner for their STCW preparation.</p>
            <a href="/signup" class="inline-block px-10 py-4 bg-white text-primary font-semibold rounded-full hover:bg-white/90 transition-all">
                Get Started for Free
            </a>
        </div>
    </section>
</Layout>

<style>
    :root {
        --page-width: 1400px;
    }
</style>
