---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const {
	title = "Bright Mariner | Maritime Exit Exam Practice",
	description = "Master your DG Shipping exit exams with our comprehensive MCQ practice platform. Featuring EFA, FPFF, PST, PSSR and more.",
	image = "/placeholder-og.jpg",
	canonicalURL = Astro.url.href,
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="BrightMarine" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- Google Analytics -->
		{gaId && (
			<>
				<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
				<script is:inline set:html={`
					window.dataLayer = window.dataLayer || [];
					function gtag(){dataLayer.push(arguments);}
					gtag('js', new Date());
					gtag('config', '${gaId}');
				`} />
			</>
		)}

		<!-- Ahrefs Analytics -->
		<script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="HwPFxo952rYzu4ClKbcyXg" async></script>

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Bright Mariner" />
		<meta name="robots" content="index, follow" />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "Organization",
						"@id": "https://brightmariner.com/#organization",
						"name": "Bright Mariner",
						"url": "https://brightmariner.com",
						"logo": {
							"@type": "ImageObject",
							"@id": "https://brightmariner.com/#logo",
							"url": "https://brightmariner.com/favicon.svg",
							"contentUrl": "https://brightmariner.com/favicon.svg",
							"caption": "Bright Mariner"
						},
						"image": {
							"@id": "https://brightmariner.com/#logo"
						}
					},
					{
						"@type": "WebSite",
						"@id": "https://brightmariner.com/#website",
						"url": "https://brightmariner.com",
						"name": "Bright Mariner",
						"description": "Maritime Exit Exam Practice Platform",
						"publisher": {
							"@id": "https://brightmariner.com/#organization"
						},
						"potentialAction": [
							{
								"@type": "SearchAction",
								"target": {
									"@type": "EntryPoint",
									"urlTemplate": "https://brightmariner.com/search?q={search_term_string}"
								},
								"query-input": "required name=search_term_string"
							}
						],
						"inLanguage": "en-US"
					}
				]
			}
		</script>
        
        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Geist+Mono:wght@400&display=swap" media="print" onload="this.media='all'">
        <noscript>
            <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;900&family=Geist+Mono:wght@400&display=swap">
        </noscript>
	</head>
	<body class="flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
        
        <footer class="bg-canvas border-t border-hairline py-16 px-6 lg:px-8 mt-auto">
            <div class="max-w-(--page-width) mx-auto grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-12">
                <div class="col-span-2 lg:col-span-1 flex flex-col gap-4">
                    <div class="flex items-center gap-2">
                        <img src="/favicon.svg" alt="BrightMariner Logo" class="w-6 h-6 rounded-sm" />
                        <span class="font-semibold text-base tracking-tight">BrightMariner</span>
                    </div>
                    <p class="text-sm text-body">
                        The modern standard for maritime exit exam preparation.
                    </p>
                </div>
                
                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Practice</h4>
                    <ul class="space-y-2">
                        <li><a href="/mcq/stcw-basic/" class="text-sm text-body hover:text-ink transition-colors">STCW Basic</a></li>
                        <li><a href="/mcq/stcw-advanced/" class="text-sm text-body hover:text-ink transition-colors">STCW Advanced</a></li>
                        <li><a href="/mcq/refresher/" class="text-sm text-body hover:text-ink transition-colors">Refresher Courses</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Resources</h4>
                    <ul class="space-y-2">
                        <li><a href="/blog/" class="text-sm text-body hover:text-ink transition-colors">Blog</a></li>
                        <li><a href="/calculators/" class="text-sm text-body hover:text-ink transition-colors">Calculators</a></li>
                        <li><a href="/study-guides/" class="text-sm text-body hover:text-ink transition-colors">Study Guides</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Company</h4>
                    <ul class="space-y-2">
                        <li><a href="/about-us/" class="text-sm text-body hover:text-ink transition-colors">About</a></li>
                        <li><a href="/contact-us/" class="text-sm text-body hover:text-ink transition-colors">Contact</a></li>
                        <li><a href="/privacy-policy/" class="text-sm text-body hover:text-ink transition-colors">Privacy</a></li>
                    </ul>
                </div>
            </div>
            <div class="max-w-(--page-width) mx-auto mt-16 pt-8 border-t border-hairline flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-xs text-mute">© 2026 BrightMariner. All rights reserved.</p>
            </div>
        </footer>
	</body>
</html>

<style>
    :root {
        --page-width: 1400px;
    }
</style>
