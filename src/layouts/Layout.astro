---
import Header from '../components/Header.astro';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
	image?: string;
	canonicalURL?: string;
}

const {
	title = "Bright Mariner | Maritime Exit Exam Practice",
	description = "Master your DG Shipping exit exams with our comprehensive MCQ practice platform. Featuring EFA, FPFF, PST, PSSR and more.",
	image = "/placeholder-og.jpg",
	canonicalURL = Astro.url.href,
} = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="shortcut icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="apple-mobile-web-app-title" content="BrightMarine" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<meta name="author" content="Bright Mariner" />
		<meta name="robots" content="index, follow" />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={new URL(image, Astro.url)} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={new URL(image, Astro.url)} />

		<!-- Structured Data -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "Organization",
						"@id": "https://brightmariner.com/#organization",
						"name": "Bright Mariner",
						"url": "https://brightmariner.com",
						"logo": {
							"@type": "ImageObject",
							"@id": "https://brightmariner.com/#logo",
							"url": "https://brightmariner.com/favicon.svg",
							"contentUrl": "https://brightmariner.com/favicon.svg",
							"caption": "Bright Mariner"
						},
						"image": {
							"@id": "https://brightmariner.com/#logo"
						}
					},
					{
						"@type": "WebSite",
						"@id": "https://brightmariner.com/#website",
						"url": "https://brightmariner.com",
						"name": "Bright Mariner",
						"description": "Maritime Exit Exam Practice Platform",
						"publisher": {
							"@id": "https://brightmariner.com/#organization"
						},
						"potentialAction": [
							{
								"@type": "SearchAction",
								"target": {
									"@type": "EntryPoint",
									"urlTemplate": "https://brightmariner.com/search?q={search_term_string}"
								},
								"query-input": "required name=search_term_string"
							}
						],
						"inLanguage": "en-US"
					}
				]
			}
		</script>
        
        <!-- Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Geist+Mono:wght@400&display=swap" rel="stylesheet">
	</head>
	<body class="flex flex-col min-h-screen">
		<Header />
		<main class="flex-grow">
			<slot />
		</main>
        
        <footer class="bg-canvas border-t border-hairline py-16 px-6 lg:px-8 mt-auto">
            <div class="max-w-(--page-width) mx-auto grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-12">
                <div class="col-span-2 lg:col-span-1 flex flex-col gap-4">
                    <div class="flex items-center gap-2">
                        <img src="/favicon.svg" alt="BrightMariner Logo" class="w-6 h-6 rounded-sm" />
                        <span class="font-semibold text-base tracking-tight">BrightMariner</span>
                    </div>
                    <p class="text-sm text-body">
                        The modern standard for maritime exit exam preparation.
                    </p>
                </div>
                
                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Practice</h4>
                    <ul class="space-y-2">
                        <li><a href="/mcq/stcw-basic" class="text-sm text-body hover:text-ink transition-colors">STCW Basic</a></li>
                        <li><a href="/mcq/stcw-advanced" class="text-sm text-body hover:text-ink transition-colors">STCW Advanced</a></li>
                        <li><a href="/mcq/refresher" class="text-sm text-body hover:text-ink transition-colors">Refresher Courses</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Resources</h4>
                    <ul class="space-y-2">
                        <li><a href="/blog" class="text-sm text-body hover:text-ink transition-colors">Blog</a></li>
                        <li><a href="/calculators" class="text-sm text-body hover:text-ink transition-colors">Calculators</a></li>
                        <li><a href="/study-guides" class="text-sm text-body hover:text-ink transition-colors">Study Guides</a></li>
                    </ul>
                </div>

                <div>
                    <h4 class="text-xs font-mono uppercase tracking-wider text-ink mb-4">Company</h4>
                    <ul class="space-y-2">
                        <li><a href="/about-us" class="text-sm text-body hover:text-ink transition-colors">About</a></li>
                        <li><a href="/contact-us" class="text-sm text-body hover:text-ink transition-colors">Contact</a></li>
                        <li><a href="/privacy-policy" class="text-sm text-body hover:text-ink transition-colors">Privacy</a></li>
                    </ul>
                </div>
            </div>
            <div class="max-w-(--page-width) mx-auto mt-16 pt-8 border-t border-hairline flex flex-col md:flex-row justify-between items-center gap-4">
                <p class="text-xs text-mute">© 2026 BrightMariner. All rights reserved.</p>
                <div class="flex items-center gap-6">
                    <a href="https://github.com/brightmariner" class="text-mute hover:text-ink transition-colors">
                        <span class="sr-only">GitHub</span>
                        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.041-1.416-4.041-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                    </a>
                </div>
            </div>
        </footer>
	</body>
</html>

<style>
    :root {
        --page-width: 1400px;
    }
</style>
