---
import { Search } from 'lucide-react';
---

<header class="sticky top-0 z-50 w-full bg-canvas/80 backdrop-blur-md border-b border-hairline h-16">
  <div class="max-w-(--page-width) mx-auto h-full flex items-center justify-between px-6 lg:px-8">
    <div class="flex items-center gap-8">
      <a href="/" class="flex items-center gap-2">
        <div class="w-8 h-8 bg-primary rounded-sm flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-5 h-5 text-white fill-current">
                <path d="M12 2L2 22h20L12 2z" />
            </svg>
        </div>
        <span class="font-semibold text-lg tracking-tight">BrightMariner</span>
      </a>
      
      <nav class="hidden md:flex items-center gap-1">
        <a href="/mcq" class="px-3 py-1.5 text-sm text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors">Practice</a>
        <a href="/courses" class="px-3 py-1.5 text-sm text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors">Courses</a>
        <a href="/blog" class="px-3 py-1.5 text-sm text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors">Blog</a>
        <a href="/about-us" class="px-3 py-1.5 text-sm text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors">About</a>
      </nav>
    </div>

    <div class="flex items-center gap-3">
        <button class="p-2 text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors">
            <Search className="w-4 h-4" />
        </button>
        
        <!-- Mobile Menu Toggle Button -->
        <button id="mobile-menu-toggle" class="md:hidden p-2 text-body hover:text-ink hover:bg-canvas-soft-2 rounded-full transition-colors" aria-label="Toggle navigation menu" aria-expanded="false">
            <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
            <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 hidden"><line x1="18" x2="6" y1="6" y2="18"></line><line x1="6" x2="18" y1="6" y2="18"></line></svg>
        </button>
    </div>
  </div>

  <!-- Mobile Navigation Panel (Slides down from under the header) -->
  <div id="mobile-nav" class="absolute top-16 left-0 w-full bg-canvas/95 backdrop-blur-md border-b border-hairline z-40 shadow-lg transform -translate-y-full invisible opacity-0 transition-all duration-200 ease-in-out md:hidden flex flex-col gap-4 p-6">
    <nav class="flex flex-col gap-1">
      <a href="/mcq" class="px-3 py-2 text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-md transition-colors">Practice</a>
      <a href="/courses" class="px-3 py-2 text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-md transition-colors">Courses</a>
      <a href="/blog" class="px-3 py-2 text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-md transition-colors">Blog</a>
      <a href="/about-us" class="px-3 py-2 text-sm font-medium text-body hover:text-ink hover:bg-canvas-soft-2 rounded-md transition-colors">About</a>
    </nav>
  </div>
</header>

<script>
  function setupMobileMenu() {
    const toggleBtn = document.getElementById('mobile-menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');

    if (!toggleBtn || !mobileNav || !menuIcon || !closeIcon) return;

    let isOpen = false;

    const toggleMenu = () => {
      isOpen = !isOpen;
      toggleBtn.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
      
      if (isOpen) {
        mobileNav.classList.remove('-translate-y-full', 'invisible', 'opacity-0');
        mobileNav.classList.add('translate-y-0', 'visible', 'opacity-100');
        menuIcon.classList.add('hidden');
        closeIcon.classList.remove('hidden');
      } else {
        mobileNav.classList.remove('translate-y-0', 'visible', 'opacity-100');
        mobileNav.classList.add('-translate-y-full', 'invisible', 'opacity-0');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      }
    };

    // Close menu when viewport is resized to desktop width
    const handleResize = () => {
      if (window.innerWidth >= 768 && isOpen) {
        isOpen = false;
        toggleBtn.setAttribute('aria-expanded', 'false');
        mobileNav.classList.remove('translate-y-0', 'visible', 'opacity-100');
        mobileNav.classList.add('-translate-y-full', 'invisible', 'opacity-0');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      }
    };

    toggleBtn.addEventListener('click', toggleMenu);
    window.addEventListener('resize', handleResize);
  }

  // Run on initial load
  setupMobileMenu();

  // Run on view transitions if enabled
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>

<style>
    :root {
        --page-width: 1400px;
    }
</style>
