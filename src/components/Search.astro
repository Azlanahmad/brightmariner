---
// src/components/Search.astro
---
<dialog id="search-dialog" class="search-dialog" aria-label="Search site">
	<div class="search-dialog-content">
		<div class="search-header">
			<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<circle cx="11" cy="11" r="8"></circle>
				<line x1="21" y1="21" x2="16.65" y2="16.65"></line>
			</svg>
			<input type="text" id="search-input" placeholder="Search articles, guides, questions..." class="search-input" autocomplete="off" />
			<button id="close-search-btn" class="close-search-btn" aria-label="Close search">
				<kbd class="kbd-label">ESC</kbd>
			</button>
		</div>
		
		<div class="search-body">
			<div id="search-results" class="search-results"></div>
			<div id="search-initial-state" class="search-state-message">
				<p>Type a keyword to start searching...</p>
				<div class="search-shortcuts-info">
					<span>Use <kbd class="kbd-inline">⌘K</kbd> or <kbd class="kbd-inline">Ctrl+K</kbd> to search from anywhere</span>
				</div>
			</div>
			<div id="search-error-state" class="search-state-message" style="display: none;">
				<p class="error-text">Search index is not available in development. It will load in production.</p>
			</div>
		</div>
	</div>
</dialog>

<script>
	async function initSearch() {
		const dialog = document.getElementById('search-dialog') as HTMLDialogElement;
		const triggerBtn = document.getElementById('search-trigger-btn');
		const closeBtn = document.getElementById('close-search-btn');
		const input = document.getElementById('search-input') as HTMLInputElement;
		const resultsContainer = document.getElementById('search-results');
		const initialState = document.getElementById('search-initial-state');
		const errorState = document.getElementById('search-error-state');
		
		if (!dialog || !input || !resultsContainer || !initialState || !errorState) return;

		const openSearch = () => {
			if (!dialog.open) {
				dialog.showModal();
				// Delay focus slightly to ensure dialog is rendered
				setTimeout(() => input.focus(), 50);
			}
		};

		const closeSearch = () => {
			if (dialog.open) {
				dialog.close();
			}
		};

		if (triggerBtn) {
			triggerBtn.addEventListener('click', openSearch);
		}

		if (closeBtn) {
			closeBtn.addEventListener('click', closeSearch);
		}

		// Light dismiss fallback for backdrop clicks
		dialog.addEventListener('click', (event) => {
			if (event.target !== dialog) return;
			const rect = dialog.getBoundingClientRect();
			const isDialogContent = (
				rect.top <= event.clientY &&
				event.clientY <= rect.top + rect.height &&
				rect.left <= event.clientX &&
				event.clientX <= rect.left + rect.width
			);
			if (!isDialogContent) {
				closeSearch();
			}
		});

		// Keyboard shortcut (Cmd+K, Ctrl+K or / key)
		const handleKeyDown = (e: KeyboardEvent) => {
			if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
				e.preventDefault();
				if (dialog.open) {
					closeSearch();
				} else {
					openSearch();
				}
			}
			if (e.key === '/' && document.activeElement !== input && !['INPUT', 'TEXTAREA'].includes(document.activeElement?.tagName || '')) {
				e.preventDefault();
				openSearch();
			}
		};
		window.addEventListener('keydown', handleKeyDown);

		// Pagefind dynamic loader
		let pagefind: any = null;
		try {
			const pagefindPath = '/pagefind/pagefind.js';
			// @ts-ignore
			pagefind = await import(/* @vite-ignore */ pagefindPath);
			pagefind.init();
			errorState.style.display = 'none';
		} catch (error) {
			// Expected during local development if pagefind files aren't copied to public
			console.warn('Pagefind index not found. This is normal in development mode.', error);
			errorState.style.display = 'block';
			initialState.style.display = 'none';
		}

		// Search event handler
		input.addEventListener('input', async (e) => {
			const query = (e.target as HTMLInputElement).value.trim();
			
			if (!query) {
				resultsContainer.innerHTML = '';
				resultsContainer.style.display = 'none';
				if (pagefind) {
					initialState.style.display = 'block';
					errorState.style.display = 'none';
				} else {
					initialState.style.display = 'none';
					errorState.style.display = 'block';
				}
				return;
			}

			initialState.style.display = 'none';

			if (!pagefind) {
				errorState.style.display = 'block';
				return;
			}

			try {
				const search = await pagefind.search(query);
				const results = await Promise.all(search.results.slice(0, 5).map((r: any) => r.data()));

				if (results.length === 0) {
					resultsContainer.innerHTML = '<div class="no-results">No results found.</div>';
				} else {
					resultsContainer.innerHTML = results.map((r: any) => `
						<a href="${r.url}" class="search-result-item">
							<div class="result-title">${r.meta.title || 'Untitled'}</div>
							<div class="result-excerpt">${r.excerpt}</div>
						</a>
					`).join('');
				}
				resultsContainer.style.display = 'block';
			} catch (err) {
				console.error('Error searching pagefind:', err);
				resultsContainer.innerHTML = '<div class="no-results error-text">Search failed to execute.</div>';
				resultsContainer.style.display = 'block';
			}
		});

		// Clean up global listener on before-swap to avoid duplicates
		document.addEventListener('astro:before-swap', () => {
			window.removeEventListener('keydown', handleKeyDown);
		}, { once: true });
	}

	// Initialize on page load
	initSearch();
	document.addEventListener('astro:after-swap', initSearch);
</script>

<style>
	/* Style the dialog element itself */
	.search-dialog {
		border: none;
		border-radius: 12px;
		padding: 0;
		width: 90%;
		max-width: 600px;
		background: var(--color-canvas);
		color: var(--color-ink);
		box-shadow: 0px 20px 25px -5px rgba(0, 0, 0, 0.1), 0px 8px 10px -6px rgba(0, 0, 0, 0.1);
		overflow: hidden;
		margin: 12vh auto auto auto;
	}

	/* Style the backdrop */
	.search-dialog::backdrop {
		background-color: rgba(23, 23, 23, 0.4);
		backdrop-filter: blur(4px);
	}

	.search-dialog-content {
		display: flex;
		flex-direction: column;
		width: 100%;
		max-height: 75vh;
	}

	.search-header {
		display: flex;
		align-items: center;
		padding: 16px;
		border-bottom: 1px solid var(--color-hairline);
		gap: 12px;
		background: var(--color-canvas-soft);
	}

	.search-icon {
		color: var(--color-mute);
		flex-shrink: 0;
	}

	.search-input {
		flex-grow: 1;
		border: none;
		outline: none;
		background: transparent;
		font-size: 16px;
		font-family: var(--font-geist);
		color: var(--color-ink);
		padding: 0;
	}

	.search-input::placeholder {
		color: var(--color-mute);
	}

	.close-search-btn {
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 4px;
		border-radius: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.close-search-btn:hover {
		background: var(--color-canvas-soft-2);
	}

	.kbd-label {
		font-family: var(--font-mono);
		font-size: 10px;
		font-weight: 600;
		color: var(--color-mute);
		background: var(--color-canvas);
		border: 1px solid var(--color-hairline-strong);
		padding: 2px 6px;
		border-radius: 4px;
		box-shadow: 0 1px 0 rgba(0, 0, 0, 0.1);
	}

	.kbd-inline {
		font-family: var(--font-mono);
		font-size: 11px;
		font-weight: 600;
		color: var(--color-body);
		background: var(--color-canvas-soft-2);
		border: 1px solid var(--color-hairline-strong);
		padding: 1px 4px;
		border-radius: 4px;
	}

	.search-body {
		overflow-y: auto;
		max-height: 50vh;
		background: var(--color-canvas);
	}

	.search-results {
		display: none;
	}

	.search-result-item {
		display: block;
		padding: 16px;
		text-decoration: none;
		border-bottom: 1px solid var(--color-hairline);
		transition: background-color 0.15s ease;
	}

	.search-result-item:last-child {
		border-bottom: none;
	}

	.search-result-item:hover, .search-result-item:focus-visible {
		background-color: var(--color-canvas-soft);
		outline: none;
	}

	.result-title {
		font-size: 15px;
		font-weight: 600;
		color: var(--color-ink);
		margin-bottom: 4px;
	}

	.result-excerpt {
		font-size: 13px;
		color: var(--color-body);
		line-height: 1.5;
	}

	.result-excerpt :global(mark) {
		background-color: rgba(0, 112, 243, 0.12);
		color: var(--color-link);
		font-weight: 600;
		padding: 0 2px;
		border-radius: 2px;
	}

	.search-state-message {
		padding: 40px 20px;
		text-align: center;
		color: var(--color-mute);
		font-size: 14px;
	}

	.search-shortcuts-info {
		font-size: 12px;
		margin-top: 10px;
		color: var(--color-mute);
	}

	.error-text {
		color: #ef4444;
	}

	.no-results {
		padding: 40px 20px;
		font-size: 14px;
		color: var(--color-mute);
		text-align: center;
	}
</style>
