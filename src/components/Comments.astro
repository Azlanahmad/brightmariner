---
// src/components/Comments.astro
const repo = import.meta.env.PUBLIC_GISCUS_REPO;
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY || 'Announcements';
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;

const isConfigured = repo && repoId && categoryId && repo !== "[YOUR_USERNAME]/[YOUR_REPO]" && repoId !== "[YOUR_REPO_ID]";
---

<div class="comments-section">
	{isConfigured ? (
		<div class="giscus-container">
			<script src="https://giscus.app/client.js"
					data-repo={repo}
					data-repo-id={repoId}
					data-category={category}
					data-category-id={categoryId}
					data-mapping="pathname"
					data-strict="0"
					data-reactions-enabled="1"
					data-emit-metadata="0"
					data-input-position="top"
					data-theme="light"
					data-lang="en"
					crossorigin="anonymous"
					async>
			</script>
		</div>
	) : (
		<div class="comments-placeholder-container">
			<div class="placeholder-header">
				<h2 class="comments-title">Comments</h2>
				<span class="setup-badge">Preview Mode</span>
			</div>
			
			<div class="mock-comments">
				<!-- Mock Comment 1 -->
				<div class="mock-comment">
					<div class="comment-avatar avatar-1">RS</div>
					<div class="comment-content">
						<div class="comment-meta">
							<span class="comment-author">Rahul Sharma</span>
							<span class="comment-badge">Deck Cadet</span>
							<span class="comment-time">2 days ago</span>
						</div>
						<p class="comment-text">The questions in PSSR set 3 were exactly what I got in my exit exam today. Thank you so much for putting this together!</p>
					</div>
				</div>

				<!-- Mock Comment 2 -->
				<div class="mock-comment">
					<div class="comment-avatar avatar-2">AA</div>
					<div class="comment-content">
						<div class="comment-meta">
							<span class="comment-author">Amit Anand</span>
							<span class="comment-badge">Engine Cadet</span>
							<span class="comment-time">5 days ago</span>
						</div>
						<p class="comment-text">Very helpful simulator. Are you planning to add Refresher FPFF questions as well? Keep up the good work!</p>
					</div>
				</div>
			</div>

			<!-- Mock Comment Form -->
			<div class="mock-form">
				<div class="form-avatar">U</div>
				<div class="form-input-container">
					<textarea class="mock-textarea" placeholder="Join the discussion... (Setup comments to enable writing)" disabled></textarea>
					<div class="form-footer">
						<span class="form-tip">Powered by Giscus & GitHub Discussions</span>
						<button class="mock-submit" disabled>Post Comment</button>
					</div>
				</div>
			</div>

			<!-- Setup Guide Card -->
			<div class="setup-guide-card card-shadow">
				<div class="guide-header">
					<svg class="guide-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
					</svg>
					<h3 class="guide-title">Configure Live Comments</h3>
				</div>
				<p class="guide-description">
					Enable discussions on your website by connecting Giscus to your GitHub repository. Follow these simple steps:
				</p>
				<ol class="guide-steps">
					<li>
						<strong>Enable Discussions:</strong> Go to your GitHub repository settings for <a href={`https://github.com/${repo || 'Azlanahmad/brightmariner'}/settings`} target="_blank" rel="noopener noreferrer"><code>{repo || 'Azlanahmad/brightmariner'}</code></a> and check the <strong>Discussions</strong> checkbox under Features.
					</li>
					<li>
						<strong>Install Giscus:</strong> Grant access to the <a href="https://github.com/apps/giscus" target="_blank" rel="noopener noreferrer">Giscus GitHub App</a> on your repository.
					</li>
					<li>
						<strong>Get ID Parameters:</strong> Visit <a href="https://giscus.app" target="_blank" rel="noopener noreferrer">giscus.app</a>, enter <code>{repo || 'Azlanahmad/brightmariner'}</code> in the repository field, and locate your generated <code>data-repo-id</code> and <code>data-category-id</code>.
					</li>
					<li>
						<strong>Save settings:</strong> Open your local <code>.env</code> file (or your hosting environment variables) and set the values:
						<pre class="code-block">
PUBLIC_GISCUS_REPO_ID="your_repo_id"
PUBLIC_GISCUS_CATEGORY_ID="your_category_id"</pre>
					</li>
				</ol>
				<div class="guide-footer">
					<a href="https://giscus.app" target="_blank" rel="noopener noreferrer" class="btn-setup">
						Go to Giscus Setup
						<svg class="btn-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
						</svg>
					</a>
				</div>
			</div>
		</div>
	)}
</div>

<style>
	.comments-section {
		margin-top: 48px;
		border-top: 1px solid var(--color-hairline, #ebebeb);
		padding-top: 32px;
	}
	.comments-title {
		font-size: 20px;
		font-weight: 600;
		letter-spacing: -0.5px;
		color: var(--color-ink, #171717);
		margin: 0;
	}
	.giscus-container {
		margin-top: 24px;
	}
	.comments-placeholder-container {
		display: flex;
		flex-direction: column;
		gap: 24px;
		margin-top: 16px;
	}
	.placeholder-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.setup-badge {
		font-family: var(--font-mono, monospace);
		font-size: 11px;
		background: #fef3c7;
		color: #d97706;
		padding: 4px 8px;
		border-radius: var(--radius-sm, 6px);
		font-weight: 600;
		border: 1px solid #fde68a;
		letter-spacing: 0.05em;
		text-transform: uppercase;
	}
	.mock-comments {
		display: flex;
		flex-direction: column;
		gap: 20px;
		background: var(--color-canvas, #ffffff);
		border: 1px solid var(--color-hairline, #ebebeb);
		border-radius: var(--radius-lg, 12px);
		padding: 24px;
	}
	.mock-comment {
		display: flex;
		gap: 16px;
		align-items: flex-start;
	}
	.comment-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 13px;
		font-weight: 600;
		color: #ffffff;
		flex-shrink: 0;
	}
	.avatar-1 {
		background: linear-gradient(135deg, #007cf0, #00dfd8);
	}
	.avatar-2 {
		background: linear-gradient(135deg, #7928ca, #ff0080);
	}
	.comment-content {
		flex-grow: 1;
	}
	.comment-meta {
		display: flex;
		align-items: center;
		gap: 8px;
		flex-wrap: wrap;
		margin-bottom: 6px;
	}
	.comment-author {
		font-size: 14px;
		font-weight: 600;
		color: var(--color-ink, #171717);
	}
	.comment-badge {
		font-size: 11px;
		background: var(--color-canvas-soft-2, #f5f5f5);
		color: var(--color-mute, #888888);
		padding: 2px 6px;
		border-radius: var(--radius-xs, 4px);
		border: 1px solid var(--color-hairline, #ebebeb);
		font-weight: 500;
	}
	.comment-time {
		font-size: 12px;
		color: var(--color-mute, #888888);
		margin-left: auto;
	}
	.comment-text {
		font-size: 14px;
		line-height: 1.5;
		color: var(--color-body, #4d4d4d);
		margin: 0;
	}
	
	/* Form styling */
	.mock-form {
		display: flex;
		gap: 16px;
		background: var(--color-canvas, #ffffff);
		border: 1px solid var(--color-hairline, #ebebeb);
		border-radius: var(--radius-lg, 12px);
		padding: 24px;
	}
	.form-avatar {
		width: 36px;
		height: 36px;
		border-radius: 50%;
		background: #cbd5e1;
		color: #ffffff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 13px;
		font-weight: 600;
		flex-shrink: 0;
	}
	.form-input-container {
		flex-grow: 1;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.mock-textarea {
		width: 100%;
		min-height: 80px;
		padding: 12px;
		border: 1px solid var(--color-hairline, #ebebeb);
		border-radius: var(--radius-md, 8px);
		font-size: 14px;
		font-family: inherit;
		resize: vertical;
		color: var(--color-ink, #171717);
		background: var(--color-canvas-soft, #fafafa);
		cursor: not-allowed;
	}
	.mock-textarea:focus {
		outline: none;
	}
	.form-footer {
		display: flex;
		justify-content: space-between;
		align-items: center;
	}
	.form-tip {
		font-size: 12px;
		color: var(--color-mute, #888888);
	}
	.mock-submit {
		background: var(--color-primary, #171717);
		color: var(--color-on-primary, #ffffff);
		border: none;
		border-radius: var(--radius-pill, 100px);
		padding: 8px 16px;
		font-size: 14px;
		font-weight: 500;
		cursor: not-allowed;
		opacity: 0.6;
	}

	/* Guide styling */
	.setup-guide-card {
		background: linear-gradient(to bottom right, #ffffff, var(--color-canvas-soft, #fafafa));
		border: 1px solid var(--color-hairline-strong, #a1a1a1);
		border-radius: var(--radius-xl, 16px);
		padding: 32px;
		display: flex;
		flex-direction: column;
		gap: 16px;
		position: relative;
		overflow: hidden;
	}
	.setup-guide-card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		height: 4px;
		background: linear-gradient(90deg, #007cf0, #7928ca, #ff4d4d);
	}
	.guide-header {
		display: flex;
		align-items: center;
		gap: 12px;
	}
	.guide-icon {
		width: 24px;
		height: 24px;
		color: var(--color-link, #0070f3);
	}
	.guide-title {
		font-size: 18px;
		font-weight: 600;
		color: var(--color-ink, #171717);
		margin: 0;
		letter-spacing: -0.02em;
	}
	.guide-description {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-body, #4d4d4d);
		margin: 0;
	}
	.guide-steps {
		padding-left: 20px;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 12px;
	}
	.guide-steps li {
		font-size: 14px;
		line-height: 1.6;
		color: var(--color-body, #4d4d4d);
	}
	.guide-steps li strong {
		color: var(--color-ink, #171717);
	}
	.guide-steps li a {
		color: var(--color-link, #0070f3);
		text-decoration: underline;
		font-weight: 500;
	}
	.guide-steps li a:hover {
		color: var(--color-link-deep, #0761d1);
	}
	.code-block {
		background: var(--color-canvas-soft-2, #f5f5f5);
		border: 1px solid var(--color-hairline, #ebebeb);
		border-radius: var(--radius-md, 8px);
		padding: 10px 14px;
		font-family: var(--font-mono, monospace);
		font-size: 12px;
		margin: 8px 0 0 0;
		overflow-x: auto;
		color: #e06c75;
	}
	.guide-footer {
		margin-top: 8px;
		display: flex;
	}
	.btn-setup {
		display: inline-flex;
		align-items: center;
		gap: 8px;
		background: var(--color-primary, #171717);
		color: var(--color-on-primary, #ffffff);
		border-radius: var(--radius-md, 8px);
		padding: 10px 20px;
		font-size: 14px;
		font-weight: 500;
		text-decoration: none;
		transition: all 0.2s ease;
	}
	.btn-setup:hover {
		opacity: 0.9;
		transform: translateY(-1px);
	}
	.btn-icon {
		width: 16px;
		height: 16px;
	}
</style>
